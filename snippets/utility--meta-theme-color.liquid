{% # Meta Theme Color v1.1.0 %}

{% comment %}
  Changelog
  - v1.1.0 — use break for early exit
  - v1.0.0 — initial
{% endcomment %}

{% doc %}
  @description Renders the <meta name="theme-color"> tag from the theme setting. Omits when unset.

  @example {% render 'utility--meta-theme-color' %}
{% enddoc %}

{% liquid
  assign meta_theme_color = settings.meta_theme_color
  if meta_theme_color == blank
    break
  endif
%}

<meta name="theme-color" content="{{ meta_theme_color.hex_code.value }}">
