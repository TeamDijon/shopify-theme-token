{% # Structured Data v2.0.0 %}

{% comment %}
  Changelog
  - v2.0.0 — pass strict schema.org validation; switch multi-variant products to `ProductGroup` with per-variant `Product`/`Offer` nodes; emit `WebSite` on every page; add `@id` to all top-level entities for graph-merge; drop judge.me augmentation
  - v1.0.0 — initial
{% endcomment %}

{% doc %}
  @description
  Emits site-wide schema.org JSON-LD (`<script type="application/ld+json">` blocks) in the <head>:
  - Organization (always)
  - WebSite (always — needed for Sitelinks Searchbox indexing regardless of entry page)
  - BreadcrumbList (always; uses the `breadcrumb.collection` metafield convention — see `.context/docs/metafield-patterns.md`)
  - Product / ProductGroup (product pages only — switches to `ProductGroup` with per-variant `Product` nodes when `product.variants.size > 1`)

  All top-level entities carry an absolute `@id` so crawlers can graph-merge nodes emitted across pages. Per-Offer `seller` references the Organization `@id`.

  Each schema is built via `{% capture %}` with readable JSON, then squished and wrapped in a script tag. Entries accumulate into `schema_list` which is iterated once at the end — adding a new schema is one capture + one concat.

  Section- or block-scoped schemas (e.g. Article, Event) can be emitted inline by those files; multiple JSON-LD blocks on a single page is valid per the schema.org spec.

  @example {% render 'utility--structured-data' %}
{% enddoc %}

{% assign schema_list = null | uniq %}

{% # Organization schema %}
{% capture organization_schema %}
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "{{ request.origin }}#organization",
    "name": "{{ shop.name | escape }}",
    {% if shop.brand.logo != blank %}
      "logo": "{{ shop.brand.logo | image_url: width: 512 | prepend: request.origin }}",
    {% elsif settings.favicon != blank %}
      "logo": "{{ settings.favicon | image_url: width: 512 | prepend: request.origin }}",
    {% endif %}
    {% if shop.brand.short_description != blank %}
      "description": "{{ shop.brand.short_description | escape }}",
    {% endif %}
    {% if shop.brand.slogan != blank %}
      "slogan": "{{ shop.brand.slogan | escape }}",
    {% endif %}
    {% if shop.brand.metafields.social_links.size > 0 %}
      "sameAs": [
        {% for social_link in shop.brand.metafields.social_links %}
          "{{ social_link.last.value }}"{% if forloop.last == false %},{% endif %}
        {% endfor %}
      ],
    {% endif %}
    "url": "{{ request.origin }}"
  }
{% endcapture %}
{% assign schema_list = organization_schema
  | strip
  | split: ' '
  | join: ' '
  | prepend: '<script type="application/ld+json">'
  | append: '</script>'
  | uniq
%}

{% # Website schema %}
{% capture website_schema %}
  {% assign potential_search_action = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "{{ request.origin }}#website",
    "name": "{{ shop.name | escape }}",
    "url": "{{ request.origin }}",
    "publisher": { "@id": "{{ request.origin }}#organization" },
    "potentialAction": {
      "@type": "SearchAction",
      "name": "Search {{ shop.name | escape }}",
      "target": {
        "@type": "EntryPoint",
        "name": "Search entry point",
        "urlTemplate": "{{ potential_search_action }}"
      },
      "query-input": "required name=search_term_string"
    }
  }
{% endcapture %}
{% assign schema_list = website_schema
  | strip
  | split: ' '
  | join: ' '
  | prepend: '<script type="application/ld+json">'
  | append: '</script>'
  | uniq
  | concat: schema_list
%}

{% # Breadcrumb schema %}
{% capture breadcrumb_schema %}
  {% liquid
    case request.page_type
      when 'page'
        assign current_page_name = page.title
      when 'article'
        assign current_page_name = article.title
      when 'blog'
        assign current_page_name = blog.title
      else
        assign current_page_name = page_title
    endcase

    assign breadcrumb_index = 2
    if request.page_type == 'collection' or request.page_type == 'product'
      assign current_collection = product.metafields.breadcrumb.collection.value | default: product.collections[0] | default: collection

      assign breadcrumb_collection_list = current_collection | uniq
      for i in (0..9)
        assign mother_collection = current_collection.metafields.breadcrumb.collection.value
        if mother_collection == blank
          break
        endif

        assign breadcrumb_collection_list = mother_collection | uniq | concat: breadcrumb_collection_list
        assign current_collection = mother_collection
      endfor
    endif
  %}
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": "{{ request.origin }}#breadcrumb",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@id": "{{ request.origin }}",
          "name": "{{ shop.name | escape }}"
        }
      }{% if request.page_type != 'index' %},{% endif %}

      {% if request.page_type != 'index' %}
        {% if request.page_type == 'collection' or request.page_type == 'product' %}
          {% for breadcrumb_collection in breadcrumb_collection_list %}
            {
              "@type": "ListItem",
              "position": {{ breadcrumb_index }},
              "item": {
                "@id": "{{ breadcrumb_collection.url | prepend: request.origin }}",
                "name": "{{ breadcrumb_collection.title | escape }}"
              }
            }{% if forloop.last == false or request.page_type == 'product' %},{% endif %}

            {% assign breadcrumb_index = breadcrumb_index | plus: 1 %}
          {% endfor %}

          {% if request.page_type == 'product' %}
            {
              "@type": "ListItem",
              "position": {{ breadcrumb_index }},
              "item": {
                "@id": "{{ product.url | prepend: request.origin }}",
                "name": "{{ product.title | escape }}"
              }
            }
          {% endif %}
        {% else %}
          {
            "@type": "ListItem",
            "position": {{ breadcrumb_index }},
            "item": {
              "@id": "{{ canonical_url }}",
              "name": "{{ current_page_name | escape }}"
            }
          }
        {% endif %}
      {% endif %}
    ]
  }
{% endcapture %}
{% assign schema_list = breadcrumb_schema
  | strip
  | split: ' '
  | join: ' '
  | prepend: '<script type="application/ld+json">'
  | append: '</script>'
  | uniq
  | concat: schema_list
%}

{% # Product / ProductGroup schema %}
{% if request.page_type == 'product' %}
  {% capture product_schema %}
    {% liquid
      assign product_title = product.metafields.seo.title.value | default: product.title
      assign product_node_id = canonical_url | append: '#product'
      assign product_absolute_url = product.url | prepend: request.origin
      assign featured_image_url = product.featured_image | image_url: width: product.featured_image.width | prepend: request.origin

      assign category_label = product.category.name | default: product.type

      if product.variants.size > 1
        assign product_node_type = 'ProductGroup'
      else
        assign product_node_type = 'Product'
      endif
    %}
    {
      "@context": "https://schema.org",
      "@type": "{{ product_node_type }}",
      "@id": "{{ product_node_id }}",
      {% if product.variants.size > 1 %}
        "productGroupID": "{{ product.id }}",
      {% else %}
        "productID": "{{ product.id }}",
      {% endif %}
      "name": "{{ product_title | escape }}",
      "description": "{{ product.description | strip_html | escape }}",
      "url": "{{ product_absolute_url }}",
      {% if product.vendor != blank %}
        "brand": {
          "@type": "Brand",
          "name": "{{ product.vendor | escape }}"
        },
      {% endif %}
      {% if category_label != blank %}
        "category": "{{ category_label | escape }}",
      {% endif %}
      "image": {
        "@type": "ImageObject",
        "url": "{{ featured_image_url }}",
        "name": "{{ product.featured_image.alt | escape }}",
        "width": {
          "@type": "QuantitativeValue",
          "name": "Width",
          "value": {{ product.featured_image.width }},
          "unitCode": "E37"
        },
        "height": {
          "@type": "QuantitativeValue",
          "name": "Height",
          "value": {{ product.featured_image.height }},
          "unitCode": "E37"
        }
      },
      {% if product.variants.size > 1 %}
        "hasVariant": [
          {% for variant in product.variants %}
            {% if variant.image %}
              {% assign variant_image_url = variant.image | image_url: width: variant.image.width | prepend: request.origin %}
            {% else %}
              {% assign variant_image_url = featured_image_url %}
            {% endif %}
            {
              "@type": "Product",
              "@id": "{{ canonical_url }}#variant-{{ variant.id }}",
              "name": "{{ product_title | escape }} - {{ variant.title | escape }}",
              "description": "{{ product.description | strip_html | escape }}",
              "url": "{{ variant.url | prepend: request.origin }}",
              {% if variant.sku != blank %}
                "sku": "{{ variant.sku }}",
              {% endif %}
              {% if product.vendor != blank %}
                "brand": {
                  "@type": "Brand",
                  "name": "{{ product.vendor | escape }}"
                },
              {% endif %}
              "image": "{{ variant_image_url }}",
              "offers": {
                "@type": "Offer",
                "@id": "{{ canonical_url }}#offer-{{ variant.id }}",
                "name": "{{ product_title | escape }} - {{ variant.title | escape }}",
                "url": "{{ variant.url | prepend: request.origin }}",
                "price": {{ variant.price | divided_by: 100.0 }},
                "priceCurrency": "{{ cart.currency.iso_code }}",
                "availability": { "@id": {% if variant.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %} },
                "itemCondition": { "@id": "https://schema.org/NewCondition" },
                "seller": { "@id": "{{ request.origin }}#organization" }
              }
            }{% if forloop.last == false %},{% endif %}
          {% endfor %}
        ]
      {% else %}
        {% assign single_variant = product.variants.first %}
        "offers": {
          "@type": "Offer",
          "@id": "{{ canonical_url }}#offer",
          "name": "{{ product_title | escape }}",
          "url": "{{ product_absolute_url }}",
          {% if single_variant.sku != blank %}
            "sku": "{{ single_variant.sku }}",
          {% endif %}
          "price": {{ single_variant.price | divided_by: 100.0 }},
          "priceCurrency": "{{ cart.currency.iso_code }}",
          "availability": { "@id": {% if single_variant.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %} },
          "itemCondition": { "@id": "https://schema.org/NewCondition" },
          "seller": { "@id": "{{ request.origin }}#organization" }
        }
      {% endif %}
    }
  {% endcapture %}
  {% assign schema_list = product_schema
    | strip
    | split: ' '
    | join: ' '
    | prepend: '<script type="application/ld+json">'
    | append: '</script>'
    | uniq
    | concat: schema_list
  %}
{% endif %}

{% for schema in schema_list reversed %}
  {{ schema }}
{% endfor %}
