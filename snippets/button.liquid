{% # Button v1.2.2 %}

{% comment %}
  Changelog
  - v1.2.2 — emit `{{ block.shopify_attributes }}` on the root for theme-editor block selection (was missing)
  - v1.2.1 — route content_width + top-margin vars through `utility--block-layout-vars`; output unchanged
  - v1.2.0 — add `icon_position` param emitted as `icon-position:end` modifier; CSS flips flex-direction so the icon trails the label
  - v1.1.3 — secondary/tertiary variants flow through scheme `--color-foreground` / `--color-background` instead of hardcoded `#000000` / `#ffffff`, so the high-contrast pair auto-adapts when the surrounding color scheme inverts
  - v1.1.2 — link-family buttons keep the 2.75rem min-block-size touch target (only the visible padding/border/background is zeroed)
  - v1.1.1 — chain `--block-rhythm-mobile`/`--block-rhythm-desktop` as inner fallback for `margin-block-start` so section-level block rhythm applies when no per-block margin is authored
  - v1.1.0 — replace the ad-hoc `solid-primary`/`solid-secondary`/`outline`/`ghost`/`text-link` variant CSS with a 3×3 family/variant matrix (`solid-`/`outline-`/`link-` × `-primary`/`-secondary`/`-tertiary`). Variant colors compose via CSS custom properties: families set bg/border/decoration, variants set the color token. Selectors anchor on the trailing `-` of the family prefix (e.g. `*='button-style:outline-'`) so substring matches don't leak across handles. Off-list handles fall through to the default solid-primary appearance.
  - v1.0.0 — initial
{% endcomment %}

{% doc %}
  @description Renders a button or link with style variants (driven by `button_style` metaobject handle), optional leading icon, max-width cap, and responsive top spacing. Renders as `<a>` when `link` is set, otherwise as `<button type="button">`. When `open_in_new_tab` is true on a linked variant, appends `target="_blank" rel="noopener noreferrer"` plus a screen-reader-only "(opens in new tab)" string.

  @param {section} [section] - The section object containing the block
  @param {block} [block] - Block object containing the settings
  @param {string} [block_id] - Unique block ID for static renders
  @param {string} [content] - Button label. Skips render when blank.
  @param {string} [link] - URL. When blank, renders a `<button type="button">`.
  @param {boolean} [open_in_new_tab] - When true on a linked button, opens in a new tab and announces it to screen readers. Defaults to false.
  @param {metaobject} [button_style] - `button_style` metaobject. Reads `.system.handle` and emits `button-style:<handle>` modifier. Variant CSS covers a 3×3 matrix: family `solid-` / `outline-` / `link-` (filled / 1px border + transparent bg / no border + no padding + underlined) × variant `-primary` / `-secondary` / `-tertiary` (accent / black / white). The full handle set is `solid-primary` (default, redundant when set explicitly), `solid-secondary`, `solid-tertiary`, `outline-primary`, `outline-secondary`, `outline-tertiary`, `link-primary`, `link-secondary`, `link-tertiary`. Handles outside this set fall through to the default `solid-primary` appearance. New variants are added by extending this snippet's stylesheet, not the metaobject schema.
  @param {metaobject} [icon] - `icon` metaobject. Inline SVG before the label. No icon when blank.
  @param {string} [icon_position] - `'start'` (default, icon leads the label) or `'end'` (icon trails). Ignored when no icon is set.
  @param {metaobject} [content_width] - `content_width` metaobject. Reads `.width.value` (px) and applies as `max-inline-size`. No cap when blank.
  @param {number} [mobile_margin_block_start] - Top margin in px below the desktop breakpoint. Defaults to 0.
  @param {number} [desktop_margin_block_start] - Top margin in px at or above the desktop breakpoint. Defaults to 0.

  @example {% render 'button', section: section, block: block %}
{% enddoc %}

{% liquid
  assign content = content | default: block.settings.content
  if content == blank
    break
  endif

  assign link = link | default: block.settings.link
  assign open_in_new_tab = open_in_new_tab | default: block.settings.open_in_new_tab, allow_false: true | default: false, allow_false: true
  assign button_style = button_style | default: block.settings.button_style
  assign icon = icon | default: block.settings.icon
  assign icon_position = icon_position | default: block.settings.icon_position | default: 'start'
  assign content_width = content_width | default: block.settings.content_width | default: ''
  assign mobile_margin_block_start = mobile_margin_block_start | default: block.settings.mobile_margin_block_start | default: 0
  assign desktop_margin_block_start = desktop_margin_block_start | default: block.settings.desktop_margin_block_start | default: 0

  if link != blank
    assign tag = 'a'
    assign link_safe = link | escape
    assign behavior_attribute = 'href="' | append: link_safe | append: '"'
    if open_in_new_tab
      assign behavior_attribute = behavior_attribute | append: ' target="_blank" rel="noopener noreferrer"'
    endif
  else
    assign tag = 'button'
    assign behavior_attribute = 'type="button"'
  endif

  if button_style and button_style != blank
    assign modifier_list = 'button-style:' | append: button_style.system.handle
  endif

  if icon and icon != blank and icon_position == 'end'
    if modifier_list != blank
      assign modifier_list = modifier_list | append: ','
    endif
    assign modifier_list = modifier_list | append: 'icon-position:end'
  endif

  capture base_selector
    render 'utility--base-selector', section: section, block: block, identifier: block_id
  endcapture
  assign base_selector = base_selector | strip

  capture modifiers
    render 'utility--modifiers', modifier_list: modifier_list
  endcapture
%}

<{{ tag }}
  class="shopify-block shopify-block--button"
  id="{{ base_selector }}"
  {{ block.shopify_attributes }}
  {{ behavior_attribute }}
  {{ modifiers }}
>
  {%- if icon and icon != blank %}
    {% render 'icon', icon: icon %}
  {%- endif %}

  {{ content }}

  {%- if tag == 'a' and open_in_new_tab %}
    <span class="sr-only">{{ 'accessibility.opens_in_new_tab' | t }}</span>
  {%- endif %}

  {% capture dynamic_style %}
    {% render 'utility--block-layout-vars', content_width: content_width, mobile_margin_block_start: mobile_margin_block_start, desktop_margin_block_start: desktop_margin_block_start %}
  {% endcapture %}
  {% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
</{{ tag }}>

{% stylesheet %}
  @layer components {
    .shopify-block--button {
      /* Default: solid + primary (accent). Family overrides the shape vars,
         variant overrides the color vars; selectors anchor on the trailing
         dash of the family prefix so substring matches stay scoped. */
      --button-color: var(--color-primary);
      --button-color-rgb: var(--color-primary-rgb);
      --button-on-color: var(--color-primary-button-text);

      --button-bg: var(--button-color);
      --button-fg: var(--button-on-color);
      --button-border-color: var(--button-color);
      --button-padding-block: 0.75rem;
      --button-padding-inline: 1.5rem;
      --button-radius: 0.25rem;
      --button-decoration: none;
      --button-min-size: 2.75rem;

      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5em;

      max-inline-size: var(--content-width, none);
      margin-block-start: var(--mobile-margin-block-start, var(--block-rhythm-mobile, 0rem));
      padding: var(--button-padding-block) var(--button-padding-inline);
      min-block-size: var(--button-min-size);
      min-inline-size: var(--button-min-size);

      background-color: var(--button-bg);
      color: var(--button-fg);
      border: 0.0625rem solid var(--button-border-color);
      border-radius: var(--button-radius);

      text-decoration: var(--button-decoration);
      text-underline-offset: 0.2em;
      appearance: none;
      cursor: pointer;
      transition: 0.15s ease-out;

      @media (width >= 48rem) {
        margin-block-start: var(--desktop-margin-block-start, var(--block-rhythm-desktop, 0rem));
      }

      @media (prefers-reduced-motion) {
        transition-duration: 0s;
      }

      & svg {
        block-size: 0.85em;
        min-inline-size: 0.85em;
      }

      /* Icon position: end — flip flex order so the icon trails the label */
      &[data-modifiers*='icon-position:end'] {
        flex-direction: row-reverse;
      }

      &:focus-visible {
        outline: 0.125rem solid var(--color-focus-ring);
        outline-offset: 0.25rem;
      }

      /* Variant: secondary — scheme foreground/background pair (high-contrast neutral) */
      &:is(
        [data-modifiers*='button-style:solid-secondary'],
        [data-modifiers*='button-style:outline-secondary'],
        [data-modifiers*='button-style:link-secondary']
      ) {
        --button-color: var(--color-foreground);
        --button-color-rgb: var(--color-foreground-rgb);
        --button-on-color: var(--color-background);
      }

      /* Variant: tertiary — inverse of secondary. Intended for use inside
         `<media-overlay>` where the surrounding scheme is overridden to a
         darker palette; sits flush with the surrounding scheme otherwise. */
      &:is(
        [data-modifiers*='button-style:solid-tertiary'],
        [data-modifiers*='button-style:outline-tertiary'],
        [data-modifiers*='button-style:link-tertiary']
      ) {
        --button-color: var(--color-background);
        --button-color-rgb: var(--color-background-rgb);
        --button-on-color: var(--color-foreground);
      }

      /* Family: outline */
      &[data-modifiers*='button-style:outline-'] {
        --button-bg: transparent;
        --button-fg: var(--button-color);
      }

      /* Family: link. Keeps the default --button-min-size (2.75rem) so the touch
         target stays at 44×44 even though the visible padding/border/background
         are zeroed — the button just *looks* like a text link. */
      &[data-modifiers*='button-style:link-'] {
        --button-bg: transparent;
        --button-fg: var(--button-color);
        --button-border-color: transparent;
        --button-padding-block: 0;
        --button-padding-inline: 0;
        --button-radius: 0;
        --button-decoration: underline;
      }

      /* Hover: solid darkens bg; outline tints; link reduces opacity */
      &:hover {
        background-color: color-mix(in oklab, var(--button-bg), black 12%);
      }

      &[data-modifiers*='button-style:outline-']:hover {
        background-color: rgba(var(--button-color-rgb), var(--opacity-subtle, 0.05));
      }

      &[data-modifiers*='button-style:link-']:hover {
        background-color: transparent;
        opacity: 0.75;
      }
    }
  }
{% endstylesheet %}
