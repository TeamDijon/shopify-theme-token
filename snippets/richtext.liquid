{% # Richtext v1.2.1 %}

{% comment %}
  Changelog
  - v1.2.1 — internal: scheme-role var refs migrate to `--color-role-*` namespace (no API change)
  - v1.2.0 — drop `narrow` param. Same concern (max-width cap) is now expressed by `content_width` alone — merchants pick a `text-narrow` `content_width` metaobject entry (~65ch) when they want a narrow column. The `prose:narrow` modifier and the corresponding `core.css` rule are gone.
  - v1.1.2 — emit `{{ block.shopify_attributes }}` on the root for theme-editor block selection (was missing)
  - v1.1.1 — route content_width + top-margin vars through `utility--block-layout-vars` (content_width blanked in narrow mode to preserve suppression); output unchanged
  - v1.1.0 — add `text_align` param; self-center capped content_width via `margin-inline: auto`
  - v1.0.1 — chain `--block-rhythm-mobile`/`--block-rhythm-desktop` as inner fallback for `margin-block-start` so section-level block rhythm applies when no per-block margin is authored
  - v1.0.0 — initial
{% endcomment %}

{% doc %}
  @description Renders a rich-text container with prose spacing utilities, max-width, color, and responsive top spacing. Always emits the `prose` modifier so the global rich-content spacing rules from `@layer utilities` apply. For narrow readable columns, pick a `content_width` metaobject entry sized for prose (~65ch).

  @param {section} [section] - The section object containing the block
  @param {block} [block] - Block object containing the settings
  @param {string} [block_id] - Unique block ID for static renders
  @param {string} [content] - HTML rich-text body. Skips render when blank.
  @param {string} [text_align] - Inline text alignment. One of `'start'` (default), `'center'`, `'end'`.
  @param {metaobject} [content_width] - `content_width` metaobject. Reads `.width.value` (px). Full width when blank. Capped width self-centers via `margin-inline: auto`.
  @param {metaobject} [text_color] - `theme_color` metaobject. Reads `.system.handle` to consume `var(--color-<handle>)`. Falls back to `--color-role-foreground` when blank.
  @param {number} [mobile_margin_block_start] - Top margin in px below the desktop breakpoint. Defaults to 0.
  @param {number} [desktop_margin_block_start] - Top margin in px at or above the desktop breakpoint. Defaults to 0.

  @example {% render 'richtext', section: section, block: block %}
{% enddoc %}

{% liquid
  assign content = content | default: block.settings.content
  if content == blank
    break
  endif

  assign text_align = text_align | default: block.settings.text_align | default: 'start'
  assign content_width = content_width | default: block.settings.content_width | default: ''
  assign text_color = text_color | default: block.settings.text_color | default: ''
  assign mobile_margin_block_start = mobile_margin_block_start | default: block.settings.mobile_margin_block_start | default: 0
  assign desktop_margin_block_start = desktop_margin_block_start | default: block.settings.desktop_margin_block_start | default: 0

  assign modifier_list = 'prose'

  capture base_selector
    render 'utility--base-selector', section: section, block: block, identifier: block_id
  endcapture
  assign base_selector = base_selector | strip

  capture modifiers
    render 'utility--modifiers', modifier_list: modifier_list
  endcapture
%}

<div class="shopify-block shopify-block--richtext" id="{{ base_selector }}" {{ block.shopify_attributes }} {{ modifiers }}>
  {{ content }}

  {% capture dynamic_style %}
    {% if text_align != 'start' %}
      --text-align: {{ text_align }};
    {% endif %}

    {% if text_color and text_color != blank %}
      --text-color: var(--color-{{ text_color.system.handle }});
    {% endif %}

    {% render 'utility--block-layout-vars', content_width: content_width, mobile_margin_block_start: mobile_margin_block_start, desktop_margin_block_start: desktop_margin_block_start %}
  {% endcapture %}
  {% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
</div>

{% stylesheet %}
  @layer components {
    .shopify-block--richtext {
      max-inline-size: var(--content-width, 100%);
      margin-inline: auto;
      color: var(--text-color, var(--color-role-foreground));
      text-align: var(--text-align, start);
    }
  }
{% endstylesheet %}
