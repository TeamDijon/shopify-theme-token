{% # Embed v1.1.2 %}

{% comment %}
  Changelog
  - v1.1.2 — emit `{{ block.shopify_attributes }}` on the root for theme-editor block selection (was missing)
  - v1.1.1 — route content_width + top-margin vars through `utility--block-layout-vars`; output unchanged
  - v1.1.0 — route `media_size` interpretation through `utility--media-sizing` (modifier + vars modes), fixing drift with `media`: embed now honors a `fill`-handle media_size (renders 100svh via a new `sizing:fill` CSS rule) instead of silently falling back to 16/9. Ratio/height behavior unchanged.
  - v1.0.3 — when a URL is set but doesn't match a supported provider, surface an editor-only diagnostic so merchants notice the rejection instead of seeing a silent placeholder
  - v1.0.2 — youtu.be and youtube.com/shorts URL parsers split on `/` before `?`/`&`/`#` so trailing-slash variants resolve to a clean video id
  - v1.0.1 — chain `--block-rhythm-mobile`/`--block-rhythm-desktop` as inner fallback for `margin-block-start` so section-level block rhythm applies when no per-block margin is authored
  - v1.0.0 — initial
{% endcomment %}

{% doc %}
  @description
  Renders a third-party video embed (YouTube or Vimeo) as a lazy-loaded iframe inside an aspect-ratio wrapper. URL is parsed in Liquid for known provider patterns; unknown URLs render a placeholder. Iframe carries a `title` attribute for screen readers — schema-level default plus a runtime fallback via `accessibility.embedded_content`.

  Supported URL shapes:
  - YouTube: `youtube.com/watch?v=ID`, `youtu.be/ID`, `youtube.com/embed/ID`, `youtube.com/shorts/ID`
  - Vimeo: `vimeo.com/ID`, `vimeo.com/ID/HASH` (unlisted videos), `player.vimeo.com/video/ID`

  No autoplay/controls schema yet — merchants who need them append URL params manually. No click-to-load privacy gate yet — iframe loads directly with `loading="lazy"`.

  @param {section} [section] - The section object containing the block
  @param {block} [block] - Block object containing the settings
  @param {string} [block_id] - Unique block ID for static renders
  @param {string} [url] - Provider URL. Renders a placeholder when blank or unparseable.
  @param {string} [title] - Iframe title for screen readers. Falls back to `accessibility.embedded_content` translation when blank.
  @param {metaobject} [media_size] - `media_size` metaobject. Reads `.type.value` and `.value.value`. Defaults to 16/9 aspect ratio when blank.
  @param {metaobject} [content_width] - `content_width` metaobject. Caps `max-inline-size`.
  @param {number} [mobile_margin_block_start] - Top margin in px below the desktop breakpoint. Defaults to 0.
  @param {number} [desktop_margin_block_start] - Top margin in px at or above the desktop breakpoint. Defaults to 0.

  @example {% render 'embed', section: section, block: block %}
{% enddoc %}

{% liquid
  assign url = url | default: block.settings.url | default: ''
  assign title = title | default: block.settings.title
  if title == blank
    assign title = 'accessibility.embedded_content' | t
  endif
  assign media_size = media_size | default: block.settings.media_size
  assign content_width = content_width | default: block.settings.content_width | default: ''
  assign mobile_margin_block_start = mobile_margin_block_start | default: block.settings.mobile_margin_block_start | default: 0
  assign desktop_margin_block_start = desktop_margin_block_start | default: block.settings.desktop_margin_block_start | default: 0

  assign provider = ''
  assign embed_url = ''

  if url contains 'youtu.be/'
    assign provider = 'youtube'
    assign video_id = url | split: 'youtu.be/' | last | split: '/' | first | split: '?' | first | split: '&' | first | split: '#' | first
    assign embed_url = 'https://www.youtube.com/embed/' | append: video_id
  elsif url contains 'youtube.com/embed/'
    assign provider = 'youtube'
    assign embed_url = url
  elsif url contains 'youtube.com/shorts/'
    assign provider = 'youtube'
    assign video_id = url | split: 'youtube.com/shorts/' | last | split: '/' | first | split: '?' | first | split: '#' | first
    assign embed_url = 'https://www.youtube.com/embed/' | append: video_id
  elsif url contains 'youtube.com/watch'
    assign video_id = ''
    if url contains '?v='
      assign video_id = url | split: '?v=' | last | split: '&' | first | split: '#' | first
    elsif url contains '&v='
      assign video_id = url | split: '&v=' | last | split: '&' | first | split: '#' | first
    endif
    if video_id != blank
      assign provider = 'youtube'
      assign embed_url = 'https://www.youtube.com/embed/' | append: video_id
    endif
  elsif url contains 'player.vimeo.com/video/'
    assign provider = 'vimeo'
    assign embed_url = url
  elsif url contains 'vimeo.com/'
    # Vimeo path may be: ID | ID/HASH (unlisted) | channels/<name>/ID | groups/<name>/videos/ID.
    # Walk segments, take first numeric as video_id; if next is non-numeric and non-blank, treat as unlisted hash.
    assign vimeo_path = url | split: 'vimeo.com/' | last | split: '?' | first | split: '#' | first
    assign vimeo_parts = vimeo_path | split: '/'
    assign video_id = ''
    assign vimeo_hash = ''
    for part in vimeo_parts
      if part == blank
        continue
      endif
      assign part_int = part | times: 1
      if part_int > 0
        assign video_id = part
        if vimeo_parts.size > forloop.index
          assign next_part = vimeo_parts[forloop.index]
          assign next_int = next_part | times: 1
          if next_int == 0 and next_part != blank
            assign vimeo_hash = next_part
          endif
        endif
        break
      endif
    endfor
    if video_id != blank
      assign provider = 'vimeo'
      if vimeo_hash != blank
        assign embed_url = 'https://player.vimeo.com/video/' | append: video_id | append: '?h=' | append: vimeo_hash
      else
        assign embed_url = 'https://player.vimeo.com/video/' | append: video_id
      endif
    endif
  endif

  assign modifier_list = ''
  if provider != blank
    assign modifier_list = 'provider:' | append: provider
  endif

  capture sizing_modifier
    render 'utility--media-sizing', media_size: media_size, output: 'modifier'
  endcapture
  assign sizing_modifier = sizing_modifier | strip
  if sizing_modifier != blank
    if modifier_list != blank
      assign modifier_list = modifier_list | append: ','
    endif
    assign modifier_list = modifier_list | append: sizing_modifier
  endif

  capture base_selector
    render 'utility--base-selector', section: section, block: block, identifier: block_id
  endcapture
  assign base_selector = base_selector | strip

  capture modifiers
    render 'utility--modifiers', modifier_list: modifier_list
  endcapture
%}

<div class='shopify-block shopify-block--embed' id='{{ base_selector }}' {{ block.shopify_attributes }} {{ modifiers }}>
  {% if embed_url != blank %}
    {% if provider == 'youtube' %}
      <iframe
        src='{{ embed_url | escape }}'
        title='{{ title | escape }}'
        loading='lazy'
        allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
        allowfullscreen
      ></iframe>
    {% elsif provider == 'vimeo' %}
      <iframe
        src='{{ embed_url | escape }}'
        title='{{ title | escape }}'
        loading='lazy'
        allow='autoplay; fullscreen; picture-in-picture'
        allowfullscreen
      ></iframe>
    {% endif %}
  {% else %}
    {{ 'image' | placeholder_svg_tag }}
    {% if url != blank %}
      <p class='shopify-block--embed__diagnostic' role='status'>
        {{ 'blocks.embed.diagnostic.unrecognized_url' | t }}
      </p>
    {% endif %}
  {% endif %}

  {% capture dynamic_style %}
    {% render 'utility--media-sizing', media_size: media_size, output: 'vars' %}

    {% render 'utility--block-layout-vars', content_width: content_width, mobile_margin_block_start: mobile_margin_block_start, desktop_margin_block_start: desktop_margin_block_start %}
  {% endcapture %}
  {% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
</div>

{% stylesheet %}
  @layer components {
    .shopify-block--embed {
      position: relative;
      overflow: hidden;
      max-inline-size: var(--content-width, 100%);
      margin-inline: auto;
      margin-block-start: var(--mobile-margin-block-start, var(--block-rhythm-mobile, 0rem));
      aspect-ratio: 16 / 9;

      @media (width >= 48rem) {
        margin-block-start: var(--desktop-margin-block-start, var(--block-rhythm-desktop, 0rem));
      }

      /* Sizing override: aspect ratio from media_size metaobject */
      &[data-modifiers*='sizing:ratio'] {
        aspect-ratio: var(--media-ratio, 16 / 9);
      }

      /* Sizing override: explicit block-size (relative/fixed metaobject types) */
      &[data-modifiers*='sizing:height'] {
        aspect-ratio: auto;
        block-size: var(--media-height);
      }

      /* Sizing override: fill the viewport height (fill-handle media_size) */
      &[data-modifiers*='sizing:fill'] {
        aspect-ratio: auto;
        block-size: 100svh;
      }

      & > iframe,
      & > svg {
        display: block;
        position: absolute;
        inset: 0;
        inline-size: 100%;
        block-size: 100%;
        border: none;
      }

      & > .shopify-block--embed__diagnostic {
        display: none;
        position: absolute;
        inset: auto 0 0 0;
        margin: 0;
        padding: 0.5rem 0.75rem;
        background-color: rgb(0 0 0 / 0.75);
        color: white;
        font-size: 0.875rem;
        text-align: center;
      }

      /* Inset focus ring so overflow:hidden wrapper doesn't clip it */
      & > iframe:focus-visible {
        outline-offset: -0.125rem;
      }
    }

    /* Editor-only diagnostic for unparseable URLs. Hidden by default; revealed
        only when the document carries the `shopify-design-mode` modifier emitted
        by `utility--document-modifiers`. */
    html[data-modifiers*='shopify-design-mode'] .shopify-block--embed__diagnostic {
      display: block;
    }
  }
{% endstylesheet %}
