{% # Open Graph v1.2.0 %}

{% comment %}
  Changelog
  - v1.2.0 — emit `og:locale` + `og:locale:alternate` (from `localization.available_languages`); serve og:image at an explicit 1200px width with a proportional height (was declaring original dimensions while serving an unsized URL) and over https directly
  - v1.1.0 — use `name=` (not `property=`) for twitter:* meta tags per Twitter spec; add `| escape` to shop.name and article.author
  - v1.0.0 — initial
{% endcomment %}

{% doc %}
  @description Emits Open Graph and Twitter Card <meta> tags for link previews. Covers site-wide defaults plus product- and article-specific fields. Section- or block-scoped overrides can be added inline by those files when needed.

  @example {% render 'utility--open-graph' %}
{% enddoc %}

{% liquid
  assign open_graph_title = page_title | default: shop.name
  assign open_graph_url = canonical_url | default: request.origin
  assign open_graph_description = page_description | default: shop.description | default: shop.name
  assign open_graph_type = 'website'

  case request.page_type
    when 'product'
      assign open_graph_type = 'product'
    when 'article'
      assign open_graph_type = 'article'
    when 'collection'
      assign open_graph_type = 'product.group'
    when 'password'
      assign open_graph_url = request.origin
  endcase
%}

<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ open_graph_url }}">
<meta property="og:title" content="{{ open_graph_title | escape }}">
<meta property="og:type" content="{{ open_graph_type }}">
<meta property="og:description" content="{{ open_graph_description | escape }}">
<meta property="og:locale" content="{{ request.locale.iso_code }}">
{%- if localization.available_languages.size > 1 -%}
  {%- for language in localization.available_languages -%}
    {%- unless language.iso_code == request.locale.iso_code -%}
      <meta property="og:locale:alternate" content="{{ language.iso_code }}">
    {%- endunless -%}
  {%- endfor -%}
{%- endif %}

{% if request.page_type == 'product' %}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{% endif %}

{% if request.page_type == 'article' %}
  <meta property="og:article:author" content="{{ article.author | escape }}">
  <meta property="og:article:published_time" content="{{ article.published_at }}">
  <meta property="og:article:modified_time" content="{{ article.updated_at }}">
{% endif %}

{% if page_image %}
  {%- assign og_image_height = 1200 | times: page_image.height | divided_by: page_image.width -%}
  <meta property="og:image" content="{{ page_image | image_url: width: 1200 | prepend: 'https:' }}">
  <meta property="og:image:secure_url" content="{{ page_image | image_url: width: 1200 | prepend: 'https:' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{{ og_image_height }}">
  <meta property="og:image:alt" content="{{ page_image.alt | default: shop.name | escape }}">
{% endif %}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ open_graph_title | escape }}">
<meta name="twitter:description" content="{{ open_graph_description | escape }}">

{% if page_image %}
  <meta name="twitter:image" content="{{ page_image | image_url | prepend: 'https:' }}">
  <meta name="twitter:image:alt" content="{{ page_image.alt | default: shop.name | escape }}">
{% endif %}
