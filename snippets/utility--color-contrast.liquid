{% # Color contrast v1.0.0 %}

{% doc %}
  @description Returns whichever of two reference colors has the higher computed contrast against the input `color`. Echoes a hex string suitable for direct interpolation into a CSS value (e.g. inside a custom property declaration).

  Wraps Liquid's native `color_contrast` filter, which returns a 0–21 contrast ratio. Used by validation pages to pick a legible foreground per theme color.

  @param {color} color - The background color the contrast is computed against. Defaults to `#ffffff`.
  @param {color} [black] - First reference color compared against `color`. Defaults to `#000000`.
  @param {color} [white] - Second reference color compared against `color`. Defaults to `#ffffff`.

  @example {% render 'utility--color-contrast', color: section.settings.background %}
  @example {% capture fg %}{% render 'utility--color-contrast', color: '#cc0033' %}{% endcapture %}
{% enddoc %}

{% liquid
  assign color = color | default: '#ffffff'
  assign black = black | default: '#000000'
  assign white = white | default: '#ffffff'

  assign black_contrast = color | color_contrast: black
  assign white_contrast = color | color_contrast: white

  if black_contrast > white_contrast
    echo black
  else
    echo white
  endif
%}
