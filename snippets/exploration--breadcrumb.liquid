{% # Exploration breadcrumb v1.0.0 %}

{% doc %}
  @description Back-link to the exploration hub (`?view=exploration`). Drop into the top of any exploration section so authors can navigate back to the index.

  @example {% render 'exploration--breadcrumb' %}
{% enddoc %}

<a class="exploration-breadcrumb" href="?view=exploration">
  <span aria-hidden="true">&larr;</span>
  <span>Exploration</span>
</a>

{% stylesheet %}
  @layer components {
    .exploration-breadcrumb {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      margin-block-end: 1.25rem;
      font-family: ui-monospace, monospace;
      font-size: 0.8125rem;
      color: inherit;
      opacity: 0.7;
      text-decoration: none;

      &:hover,
      &:focus-visible {
        opacity: 1;
        text-decoration: underline;
        text-underline-offset: 0.2em;
      }
    }
  }
{% endstylesheet %}
