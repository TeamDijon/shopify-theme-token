{% # Validation breadcrumb v1.0.0 %}

{% doc %}
  @description Back-link to the validation hub (`?view=validation`). Drop into the top of any per-topic validation section so authors can navigate back to the index. Skipped on the hub itself.

  @example {% render 'validation--breadcrumb' %}
{% enddoc %}

<a class="validation-breadcrumb" href="?view=validation">
  <span aria-hidden="true">&larr;</span>
  <span>Validation</span>
</a>

{% stylesheet %}
  @layer components {
    .validation-breadcrumb {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      margin-block-end: 1.25rem;
      font-family: ui-monospace, monospace;
      font-size: 0.8125rem;
      color: inherit;
      opacity: 0.7;
      text-decoration: none;

      &:hover,
      &:focus-visible {
        opacity: 1;
        text-decoration: underline;
        text-underline-offset: 0.2em;
      }
    }
  }
{% endstylesheet %}
