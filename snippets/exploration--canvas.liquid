{% # Exploration canvas v1.0.0 %}

{% doc %}
  @description Shared render scaffold for every exploration section. Emits the bleed-extension CSS variable on the section root (inherited by all blocks) + the canvas wrapper that bleeding children escape from.

  @param {section} section - The section object (passed explicitly because snippets run in isolated scope)

  Variables emitted (scoped to section's #base_selector):
  - `--exploration-content-width`: 80rem (the canvas's max-inline-size)
  - `--exploration-canvas-padding-inline`: 1.5rem (escape distance on mobile + included in extension formula)
  - `--exploration-bleed-extension`: total distance a bleeding child shifts to reach viewport edge (or the 3200px background-stop cap on wide viewports)

  Formula: `max(0px, (min(100dvw, 200rem) - 80rem) / 2) + 1.5rem`. The min() caps the viewport reference at 3200px (the substrate's background-stop guard). The constant `+ 1.5rem` accounts for canvas padding-inline so mobile (viewport ≤ 80rem) still has a gutter to bleed past.

  Temporary scaffold — see BACKLOG.md § Active exploration.

  @example {% render 'exploration--canvas' %}
{% enddoc %}

{% liquid
  assign base_selector = 'shopify-section-' | append: section.id
%}

<theme-section>
  {% render 'exploration--breadcrumb' %}

  <header class="exploration__intro">
    <h1>{{ section.settings.title }}</h1>
    <p>{{ section.settings.description }}</p>
  </header>

  <div class="exploration__canvas">
    {% content_for 'blocks' %}
  </div>
</theme-section>

{% capture dynamic_style %}
  --exploration-content-width: 80rem;
  --exploration-canvas-padding-inline: 1.5rem;
  --exploration-bleed-extension: calc(max(0px, (min(100dvw, 200rem) - 80rem) / 2) + 1.5rem);
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
