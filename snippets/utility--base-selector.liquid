{% # Base selector v1.0.0 %}

{% doc %}
  @description Generates a unique DOM id string for the component based on the current render context (section, block, or static identifier).

  @param {section} section - The section object
  @param {block} [block] - The block object
  @param {string} [identifier] - Identifier for static-render components within a section

  @example {% render 'utility--base-selector', section: section, block: block %}
  @example {% render 'utility--base-selector', section: section, identifier: 'custom-id' %}
{% enddoc %}

{% liquid
  if block != null
    assign base_selector = 'shopify-block-' | append: block.id
  elsif identifier
    assign base_selector = 'shopify-section-' | append: section.id | append: '__block-' | append: identifier
  else
    assign base_selector = 'shopify-section-' | append: section.id
  endif

  echo base_selector
%}
