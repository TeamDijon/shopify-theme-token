{% # Separator v1.0.5 %}

{% comment %}
  Changelog
  - v1.0.5 — internal: scheme-role var refs migrate to `--color-role-*` namespace (no API change)
  - v1.0.4 — emit `{{ block.shopify_attributes }}` on the root for theme-editor block selection (was missing)
  - v1.0.3 — route content_width + top-margin vars through `utility--block-layout-vars`; output unchanged
  - v1.0.2 — add `inline-size: 100%` so the wrapper doesn't shrink-to-fit to 0 inside flex parents (the inner `<hr>` has no intrinsic width, and `margin-inline: auto` + `max-inline-size` alone left no resolved size on a flex item)
  - v1.0.1 — chain `--block-rhythm-mobile`/`--block-rhythm-desktop` as inner fallback for `margin-block-start` so section-level block rhythm applies when no per-block margin is authored
  - v1.0.0 — initial
{% endcomment %}

{% doc %}
  @description Renders a horizontal rule with optional max-width, line color (from a `theme_color` metaobject), and responsive top spacing.

  @param {section} [section] - The section object containing the block
  @param {block} [block] - Block object containing the settings
  @param {string} [block_id] - Unique block ID for static renders
  @param {metaobject} [content_width] - `content_width` metaobject. Reads `.width.value` (px). Full width if blank.
  @param {metaobject} [line_color] - `theme_color` metaobject. Reads `.system.handle` to consume `var(--color-<handle>)`. Falls back to `--color-role-border` if blank.
  @param {number} [mobile_margin_block_start] - Top margin in px below the desktop breakpoint. Defaults to 0.
  @param {number} [desktop_margin_block_start] - Top margin in px at or above the desktop breakpoint. Defaults to 0.

  @example {% render 'separator', section: section, block: block %}
{% enddoc %}

{% liquid
  assign content_width = content_width | default: block.settings.content_width | default: ''
  assign line_color = line_color | default: block.settings.line_color | default: ''
  assign mobile_margin_block_start = mobile_margin_block_start | default: block.settings.mobile_margin_block_start | default: 0
  assign desktop_margin_block_start = desktop_margin_block_start | default: block.settings.desktop_margin_block_start | default: 0

  capture base_selector
    render 'utility--base-selector', section: section, block: block, identifier: block_id
  endcapture
  assign base_selector = base_selector | strip
%}

<div class="shopify-block shopify-block--separator" id="{{ base_selector }}" {{ block.shopify_attributes }}>
  <hr>

  {% capture dynamic_style %}
    {% if line_color and line_color != blank %}
      --line-color: var(--color-{{ line_color.system.handle }});
    {% endif %}

    {% render 'utility--block-layout-vars', content_width: content_width, mobile_margin_block_start: mobile_margin_block_start, desktop_margin_block_start: desktop_margin_block_start %}
  {% endcapture %}
  {% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
</div>

{% stylesheet %}
  @layer components {
    .shopify-block--separator {
      inline-size: 100%;
      max-inline-size: var(--content-width, 100%);
      margin-inline: auto;

      & hr {
        margin: 0;
        border: none;
        border-block-start: 0.0625rem solid var(--line-color, var(--color-role-border));
      }
    }
  }
{% endstylesheet %}
