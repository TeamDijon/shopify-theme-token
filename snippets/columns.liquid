{% # Columns v1.2.2 %}

{% comment %}
  Changelog
  - v1.2.2 â€” emit `{{ block.shopify_attributes }}` on the root for theme-editor block selection (was missing)
  - v1.2.1 â€” route content_width + top-margin vars through `utility--block-layout-vars`; output unchanged
  - v1.2.0 â€” add `sticky_track` param emitted as `sticky-track:first`/`:second` modifier; CSS applies `position: sticky` to the named child with `align-self: start`. Sticky disables itself when stack-below has collapsed the layout to a single column. Doc block notes that the non-sticky track stays at natural height so the parent grid can grow taller than the sticky child.
  - v1.1.0 â€” add `bleed` param emitted as `,bleed` modifier; CSS escapes the section gutter to the visible viewport width (same math as media's bleed)
  - v1.0.2 â€” wrap contents in `.shopify-block--columns__inner`; container-type stays on the outer so `@container columns` queries actually match (queries never see the element that defines the container per spec). Grid/stack-below rules move to the inner wrapper.
  - v1.0.1 â€” chain `--block-rhythm-mobile`/`--block-rhythm-desktop` as inner fallback for `margin-block-start` so section-level block rhythm applies when no per-block margin is authored
  - v1.0.0 â€” initial
{% endcomment %}

{% doc %}
  @description Renders a CSS Grid container for child blocks. Seven preset column ratios (2/3/4 equal, plus â…“+â…”, â…”+â…“, ÂĽ+Âľ, Âľ+ÂĽ). Stack-below uses `@container` queries against the columns block's own width, so a columns inside a narrow parent collapses to a single column when its rendered width drops below the breakpoint, regardless of the viewport.

  @param {section} [section] - The section object containing the block
  @param {block} [block] - Block object containing the settings
  @param {string} [block_id] - Unique block ID for static renders
  @param {string} [contents] - Pre-rendered child blocks markup. Skips render when blank.
  @param {string} [columns] - Column layout. One of `'2'`, `'3'`, `'4'`, `'1-2'`, `'2-1'`, `'1-3'`, `'3-1'`. Defaults to `'2'`.
  @param {string} [stack_below] - Collapse to single column when container is below the breakpoint. One of `'none'`, `'40'`, `'60'`, `'80'` (rem). Defaults to `'60'`.
  @param {string} [vertical_alignment] - `align-items` value for grid items. One of `'start'` (default), `'center'`, `'end'`, `'stretch'`. Ignored when `sticky_track` is set â€” sticky forces start alignment so the non-sticky track can grow taller than the sticky one.
  @param {string} [sticky_track] - Pins one track while the other scrolls. `'none'` (default), `'first'`, or `'second'`. Only meaningful for 2-track layouts (`2`, `1-2`, `2-1`, `1-3`, `3-1`). Disabled when stack-below has collapsed the layout to a single column.
  @param {metaobject} [content_width] - `content_width` metaobject. Caps `max-inline-size`. Full width when blank. Ignored when `bleed` is true.
  @param {number} [gap] - Gap between columns in px. Defaults to 16.
  @param {boolean} [bleed] - Extends the columns past the section gutter to the visible viewport width (`margin-inline: calc(50% - 50dvw)`). Same constraint as `media`'s bleed: assumes a centered ancestor chain. Defaults to false.
  @param {string} [color_scheme] - Optional `color_scheme` setting value. When set, emits `color-scheme:<id>` modifier so the global scheme rules from `utility--css-variables` apply.
  @param {number} [mobile_margin_block_start] - Top margin in px below the desktop breakpoint. Defaults to 0.
  @param {number} [desktop_margin_block_start] - Top margin in px at or above the desktop breakpoint. Defaults to 0.

  @example {% render 'columns', section: section, block: block, contents: contents %}
{% enddoc %}

{% liquid
  assign columns = columns | default: block.settings.columns | default: '2'
  assign stack_below = stack_below | default: block.settings.stack_below | default: '60'
  assign vertical_alignment = vertical_alignment | default: block.settings.vertical_alignment | default: 'start'
  assign sticky_track = sticky_track | default: block.settings.sticky_track | default: 'none'
  assign content_width = content_width | default: block.settings.content_width | default: ''
  assign gap = gap | default: block.settings.gap | default: 16
  assign bleed = bleed | default: block.settings.bleed, allow_false: true | default: false, allow_false: true
  assign color_scheme = color_scheme | default: block.settings.color_scheme | default: ''
  assign mobile_margin_block_start = mobile_margin_block_start | default: block.settings.mobile_margin_block_start | default: 0
  assign desktop_margin_block_start = desktop_margin_block_start | default: block.settings.desktop_margin_block_start | default: 0

  assign modifier_list = 'columns:' | append: columns
  if stack_below != 'none'
    assign modifier_list = modifier_list | append: ',stack-below:' | append: stack_below
  endif
  if sticky_track != 'none'
    assign modifier_list = modifier_list | append: ',sticky-track:' | append: sticky_track
  endif
  if bleed
    assign modifier_list = modifier_list | append: ',bleed'
  endif
  if color_scheme != blank
    assign modifier_list = modifier_list | append: ',color-scheme:' | append: color_scheme
  endif

  capture base_selector
    render 'utility--base-selector', section: section, block: block, identifier: block_id
  endcapture
  assign base_selector = base_selector | strip

  capture modifiers
    render 'utility--modifiers', modifier_list: modifier_list
  endcapture
%}

<div class="shopify-block shopify-block--columns" id="{{ base_selector }}" {{ block.shopify_attributes }} {{ modifiers }}>
  <div class="shopify-block--columns__inner">
    {{ contents }}
  </div>

  {% capture dynamic_style %}
    {% case columns %}
      {% when '2' %}
        --grid-template-columns: repeat(2, 1fr);
      {% when '3' %}
        --grid-template-columns: repeat(3, 1fr);
      {% when '4' %}
        --grid-template-columns: repeat(4, 1fr);
      {% when '1-2' %}
        --grid-template-columns: 1fr 2fr;
      {% when '2-1' %}
        --grid-template-columns: 2fr 1fr;
      {% when '1-3' %}
        --grid-template-columns: 1fr 3fr;
      {% when '3-1' %}
        --grid-template-columns: 3fr 1fr;
    {% endcase %}

    {% if gap and gap > 0 %}
      --gap: {{ gap | divided_by: 16.0 | round: 3 }}rem;
    {% endif %}

    {% if vertical_alignment != 'start' %}
      --vertical-alignment: {{ vertical_alignment }};
    {% endif %}

    {% render 'utility--block-layout-vars', content_width: content_width, mobile_margin_block_start: mobile_margin_block_start, desktop_margin_block_start: desktop_margin_block_start %}
  {% endcapture %}
  {% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
</div>

{% stylesheet %}
  @layer components {
    /* Outer wrapper hosts the named container so descendant @container queries can match. The grid layout lives on the inner wrapper â€” querying the same element that defines the container never matches per spec. */
    .shopify-block--columns {
      container-type: inline-size;
      container-name: columns;

      max-inline-size: var(--content-width, 100%);
      margin-block-start: var(--mobile-margin-block-start, var(--block-rhythm-mobile, 0rem));

      @media (width >= 48rem) {
        margin-block-start: var(--desktop-margin-block-start, var(--block-rhythm-desktop, 0rem));
      }

      /* Bleed: escape the section gutter, span the full visible viewport.
         Same math as media's bleed; assumes a centered ancestor chain. */
      &[data-modifiers*='bleed'] {
        inline-size: 100dvw;
        max-inline-size: none;
        margin-inline: calc(50% - 50dvw);
      }
    }

    .shopify-block--columns__inner {
      display: grid;
      grid-template-columns: var(--grid-template-columns, 1fr);
      align-items: var(--vertical-alignment, start);
      gap: var(--gap, 0rem);
    }

    /* Stack-below: collapse to single column when container is narrower than the breakpoint */
    .shopify-block--columns[data-modifiers*='stack-below'] > .shopify-block--columns__inner {
      grid-template-columns: 1fr;
    }

    @container columns (inline-size >= 40rem) {
      .shopify-block--columns[data-modifiers*='stack-below:40'] > .shopify-block--columns__inner {
        grid-template-columns: var(--grid-template-columns);
      }
    }

    @container columns (inline-size >= 60rem) {
      .shopify-block--columns[data-modifiers*='stack-below:60'] > .shopify-block--columns__inner {
        grid-template-columns: var(--grid-template-columns);
      }
    }

    @container columns (inline-size >= 80rem) {
      .shopify-block--columns[data-modifiers*='stack-below:80'] > .shopify-block--columns__inner {
        grid-template-columns: var(--grid-template-columns);
      }
    }

    /* Sticky track â€” pin one column while the other scrolls. `align-self: start` keeps the sticky child at its natural height so the parent grid can grow taller than it; the non-sticky child remains free to size itself, providing the scroll runway. */
    .shopify-block--columns[data-modifiers*='sticky-track:first'] > .shopify-block--columns__inner > :first-child,
    .shopify-block--columns[data-modifiers*='sticky-track:second'] > .shopify-block--columns__inner > :last-child {
      position: sticky;
      top: var(--sticky-offset, 1rem);
      align-self: start;
    }

    /* Disable sticky when stack-below has collapsed the grid to a single column. */
    .shopify-block--columns[data-modifiers*='stack-below'] > .shopify-block--columns__inner > * {
      position: static;
    }

    /* Re-enable sticky inside the same @container queries that re-enable the grid. */
    @container columns (inline-size >= 40rem) {
      .shopify-block--columns[data-modifiers*='stack-below:40'][data-modifiers*='sticky-track:first'] > .shopify-block--columns__inner > :first-child,
      .shopify-block--columns[data-modifiers*='stack-below:40'][data-modifiers*='sticky-track:second'] > .shopify-block--columns__inner > :last-child {
        position: sticky;
      }
    }

    @container columns (inline-size >= 60rem) {
      .shopify-block--columns[data-modifiers*='stack-below:60'][data-modifiers*='sticky-track:first'] > .shopify-block--columns__inner > :first-child,
      .shopify-block--columns[data-modifiers*='stack-below:60'][data-modifiers*='sticky-track:second'] > .shopify-block--columns__inner > :last-child {
        position: sticky;
      }
    }

    @container columns (inline-size >= 80rem) {
      .shopify-block--columns[data-modifiers*='stack-below:80'][data-modifiers*='sticky-track:first'] > .shopify-block--columns__inner > :first-child,
      .shopify-block--columns[data-modifiers*='stack-below:80'][data-modifiers*='sticky-track:second'] > .shopify-block--columns__inner > :last-child {
        position: sticky;
      }
    }
  }
{% endstylesheet %}
