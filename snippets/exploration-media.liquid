{% # Exploration Media v1.0.0 %}

{% doc %}
  @description Placeholder media block for bleed-API exploration. Renders a Shopify `image` placeholder SVG inside a sized box. Tests per-side desktop bleed + binary mobile bleed.

  @param {section} [section]
  @param {block} [block]

  Settings:
  - `bleed_desktop`: none / inline-start / inline-end / both
  - `bleed_mobile`: none / both
  - `aspect_ratio`: 1/1, 16/9, 4/3, 3/2

  Discards expected when shipped-block API decisions land. See `BACKLOG.md` § Active exploration.
{% enddoc %}

{% liquid
  assign bleed_desktop = block.settings.bleed_desktop | default: 'none'
  assign bleed_mobile = block.settings.bleed_mobile | default: 'none'
  assign aspect_ratio = block.settings.aspect_ratio | default: '16/9'

  assign modifier_list = ''
  if bleed_desktop != 'none'
    assign modifier_list = 'bleed-desktop:' | append: bleed_desktop
  endif
  if bleed_mobile != 'none'
    if modifier_list != blank
      assign modifier_list = modifier_list | append: ','
    endif
    assign modifier_list = modifier_list | append: 'bleed-mobile:' | append: bleed_mobile
  endif

  capture base_selector
    render 'utility--base-selector', section: section, block: block
  endcapture
  assign base_selector = base_selector | strip

  capture modifiers
    render 'utility--modifiers', modifier_list: modifier_list
  endcapture
%}

<div class="shopify-block shopify-block--exploration-media" id="{{ base_selector }}" {{ block.shopify_attributes }} {{ modifiers }}>
  {{ 'image' | placeholder_svg_tag: 'exploration-media__placeholder' }}
</div>

{% capture dynamic_style %}
  --aspect-ratio: {{ aspect_ratio }};
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% stylesheet %}
  @layer components {
    .shopify-block--exploration-media {
      display: block;
      inline-size: 100%;
      aspect-ratio: var(--aspect-ratio, 16/9);
      background: rgba(0, 0, 0, 0.08);
      overflow: hidden;
      position: relative;

      & .exploration-media__placeholder {
        inline-size: 100%;
        block-size: 100%;
        object-fit: cover;
        fill: rgba(0, 0, 0, 0.25);
      }

      /* Mobile bleed — below 48rem */
      @media (max-width: 47.99rem) {
        &[data-modifiers*='bleed-mobile:both'] {
          margin-inline: calc(-1 * var(--exploration-bleed-extension, 0px));
          inline-size: calc(100% + var(--exploration-bleed-extension, 0px) * 2);
        }
      }

      /* Desktop bleed — 48rem+ */
      @media (min-width: 48rem) {
        &[data-modifiers*='bleed-desktop:both'] {
          margin-inline: calc(-1 * var(--exploration-bleed-extension, 0px));
          inline-size: calc(100% + var(--exploration-bleed-extension, 0px) * 2);
        }
        &[data-modifiers*='bleed-desktop:inline-start'] {
          margin-inline-start: calc(-1 * var(--exploration-bleed-extension, 0px));
          inline-size: calc(100% + var(--exploration-bleed-extension, 0px));
        }
        &[data-modifiers*='bleed-desktop:inline-end'] {
          margin-inline-end: calc(-1 * var(--exploration-bleed-extension, 0px));
          inline-size: calc(100% + var(--exploration-bleed-extension, 0px));
        }
      }
    }
  }
{% endstylesheet %}
