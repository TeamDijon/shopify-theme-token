# Enforce LF line endings for all text files on every platform, so prettier
# (endOfLine: lf), theme-check, and the Shopify CLI see consistent endings
# regardless of each contributor's core.autocrlf. Without this, a Windows
# checkout (autocrlf=true) rewrites text files to CRLF and fails `npm run check`.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.mp4 binary
*.webm binary
