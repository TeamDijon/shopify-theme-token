/*
 * Token — milestone-1 homepage.
 * Hand-authored demo composition (hero → features → content → CTA) selling the
 * theme itself. Metaobject-typed settings reference entries by handle
 * (content_width, media_size, button_style, spacing) — portable across any
 * seeded store. The reusable compositions live as presets in sections/section.liquid.
 */
{
  "sections": {
    "hero": {
      "type": "section",
      "settings": {},
      "blocks": {
        "media": {
          "type": "media",
          "settings": {
            "media_size": "half-screen",
            "bleed_desktop": "both",
            "bleed_mobile": "both",
            "overlay_color": "rgba(0,0,0,0.45)",
            "custom_color_scheme": true,
            "color_scheme": "scheme-3",
            "horizontal_alignment": "center",
            "vertical_alignment": "center"
          },
          "blocks": {
            "title": {
              "type": "title",
              "settings": {
                "content": "Design is data. Layout is yours.",
                "tag": "h1",
                "text_align": "center"
              }
            },
            "text": {
              "type": "richtext",
              "settings": {
                "content": "<p>Token keeps every color, type style, and rhythm in metaobjects — so your storefront is a system you compose, not a template you fight.</p>",
                "text_align": "center"
              }
            },
            "button": {
              "type": "button",
              "settings": {
                "content": "Explore the system",
                "link": "/",
                "button_style": "solid-primary"
              }
            }
          },
          "block_order": ["title", "text", "button"]
        }
      },
      "block_order": ["media"]
    },
    "features": {
      "type": "section",
      "settings": {
        "content_width": "medium",
        "block_rhythm": "md"
      },
      "blocks": {
        "spacer_top": { "type": "spacer", "settings": { "size": "lg" } },
        "heading": {
          "type": "title",
          "settings": {
            "content": "Why Token",
            "tag": "h2",
            "text_align": "center"
          }
        },
        "columns": {
          "type": "columns",
          "settings": {
            "columns": "3",
            "gap": 24,
            "stack_below": "60",
            "vertical_alignment": "start"
          },
          "blocks": {
            "card_1": {
              "type": "richtext",
              "settings": {
                "content": "<h3>Design as data</h3><p>Colors, type, spacing, and widths live in metaobjects. Tune the system once and every block follows.</p>"
              }
            },
            "card_2": {
              "type": "richtext",
              "settings": {
                "content": "<h3>Compose, don't configure</h3><p>Nine primitives — title, media, columns, groups and more — assemble into any section without bespoke code.</p>"
              }
            },
            "card_3": {
              "type": "richtext",
              "settings": {
                "content": "<h3>Portable by design</h3><p>Presets ship free of store-specific references, so a layout drops cleanly into any store.</p>"
              }
            }
          },
          "block_order": ["card_1", "card_2", "card_3"]
        },
        "spacer_bottom": { "type": "spacer", "settings": { "size": "lg" } }
      },
      "block_order": ["spacer_top", "heading", "columns", "spacer_bottom"]
    },
    "content": {
      "type": "section",
      "settings": {
        "content_width": "reading",
        "block_rhythm": "md",
        "custom_color_scheme": true,
        "color_scheme": "scheme-2"
      },
      "blocks": {
        "spacer_top": { "type": "spacer", "settings": { "size": "lg" } },
        "heading": {
          "type": "title",
          "settings": {
            "content": "A substrate, not a stack of sections",
            "tag": "h2",
            "text_align": "center"
          }
        },
        "body": {
          "type": "richtext",
          "settings": {
            "content": "<p>Most themes grow one section at a time. Token starts from a design substrate — metaobjects, color schemes, a bleed grid, and vertical rhythm — and lets a handful of blocks express the rest. Less code to maintain, more layouts to reach.</p>",
            "text_align": "center"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "content": "Read the architecture",
            "link": "/",
            "button_style": "outline-primary"
          }
        },
        "spacer_bottom": { "type": "spacer", "settings": { "size": "lg" } }
      },
      "block_order": ["spacer_top", "heading", "body", "button", "spacer_bottom"]
    },
    "cta": {
      "type": "section",
      "settings": {
        "content_width": "reading",
        "block_rhythm": "lg",
        "custom_color_scheme": true,
        "color_scheme": "scheme-3"
      },
      "blocks": {
        "spacer_top": { "type": "spacer", "settings": { "size": "lg" } },
        "rule_top": { "type": "separator", "settings": {} },
        "heading": {
          "type": "title",
          "settings": {
            "content": "Start from the system.",
            "tag": "h2",
            "text_align": "center"
          }
        },
        "actions": {
          "type": "group",
          "settings": {
            "direction": "row",
            "horizontal_alignment": "center",
            "gap": 16
          },
          "blocks": {
            "button_primary": {
              "type": "button",
              "settings": {
                "content": "Get Token",
                "link": "/",
                "button_style": "solid-primary"
              }
            },
            "button_secondary": {
              "type": "button",
              "settings": {
                "content": "See the blocks",
                "link": "/",
                "button_style": "outline-primary"
              }
            }
          },
          "block_order": ["button_primary", "button_secondary"]
        },
        "rule_bottom": { "type": "separator", "settings": {} },
        "spacer_bottom": { "type": "spacer", "settings": { "size": "lg" } }
      },
      "block_order": ["spacer_top", "rule_top", "heading", "actions", "rule_bottom", "spacer_bottom"]
    }
  },
  "order": ["hero", "features", "content", "cta"]
}
