{
  "sections": {
    "main": {
      "type": "validation--primitive--button",
      "blocks": {
        "no-link": {
          "type": "button",
          "settings": {
            "content": "Submit"
          }
        },
        "with-link": {
          "type": "button",
          "settings": {
            "content": "Read more",
            "link": "/"
          }
        },
        "external-link": {
          "type": "button",
          "settings": {
            "content": "External site",
            "link": "https://example.com",
            "open_in_new_tab": true
          }
        },
        "with-spacing": {
          "type": "button",
          "settings": {
            "content": "After 64px desktop margin",
            "link": "/",
            "mobile_margin_block_start": 16,
            "desktop_margin_block_start": 64
          }
        },
        "tight-spacing": {
          "type": "button",
          "settings": {
            "content": "Tight spacing",
            "link": "/",
            "mobile_margin_block_start": 8,
            "desktop_margin_block_start": 16
          }
        },
        "icon-end": {
          "type": "button",
          "settings": {
            "content": "Icon trails",
            "link": "/",
            "icon": "arrow",
            "icon_position": "end"
          }
        },
        "icon-start": {
          "type": "button",
          "settings": {
            "content": "Icon leads",
            "link": "/",
            "icon": "arrow",
            "icon_position": "start"
          }
        },
        "combo": {
          "type": "button",
          "settings": {
            "content": "Combo",
            "link": "/",
            "button_style": "outline-primary",
            "icon": "arrow",
            "icon_position": "end"
          }
        },
        "link-style": {
          "type": "button",
          "settings": {
            "content": "Link style",
            "link": "/",
            "button_style": "link-primary"
          }
        },
        "escaped-content": {
          "type": "button",
          "settings": {
            "content": "Save <b>50%</b>",
            "link": "/"
          }
        },
        "escaped-href": {
          "type": "button",
          "settings": {
            "content": "Escaped href",
            "link": "/x\" data-x=\"y"
          }
        },
        "width-capped": {
          "type": "button",
          "settings": {
            "content": "Capped width",
            "link": "/",
            "content_width": "reading"
          }
        },
        "full-always": {
          "type": "button",
          "settings": {
            "content": "Full width always",
            "link": "/",
            "full_width": "always"
          }
        },
        "full-mobile": {
          "type": "button",
          "settings": {
            "content": "Full width on mobile",
            "link": "/",
            "full_width": "mobile"
          }
        },
        "full-capped": {
          "type": "button",
          "settings": {
            "content": "Full and capped",
            "link": "/",
            "full_width": "always",
            "content_width": "reading"
          }
        },
        "blank": {
          "type": "button",
          "settings": {
            "content": ""
          }
        }
      },
      "block_order": [
        "no-link",
        "with-link",
        "external-link",
        "with-spacing",
        "tight-spacing",
        "icon-end",
        "icon-start",
        "combo",
        "link-style",
        "escaped-content",
        "escaped-href",
        "width-capped",
        "full-always",
        "full-mobile",
        "full-capped",
        "blank"
      ],
      "settings": {}
    }
