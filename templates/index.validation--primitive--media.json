{
  "sections": {
    "main": {
      "type": "validation--primitive--media",
      "blocks": {
        "image-placeholder": {
          "type": "media",
          "settings": { "media_type": "image", "media_size": "16-9" }
        },
        "size-ratio-11": {
          "type": "media",
          "settings": { "media_type": "image", "media_size": "1-1" }
        },
        "size-relative-half": {
          "type": "media",
          "settings": { "media_type": "image", "media_size": "half-screen" }
        },
        "size-fill": {
          "type": "media",
          "settings": { "media_type": "image", "media_size": "fill" }
        },
        "type-video": {
          "type": "media",
          "settings": { "media_type": "video", "video_mode": "atmosphere", "media_size": "16-9" }
        },
        "fit-contain": {
          "type": "media",
          "settings": { "media_type": "image", "image_fit": "contain", "media_size": "16-9" }
        },
        "overlay-tint": {
          "type": "media",
          "settings": { "media_type": "image", "media_size": "16-9", "overlay_color": "rgba(0, 51, 153, 0.4)" }
        },
        "bleed-both": {
          "type": "media",
          "settings": {
            "media_type": "image",
            "media_size": "16-9",
            "bleed_desktop": "both",
            "bleed_mobile": "both"
          }
        },
        "bleed-start": {
          "type": "media",
          "settings": { "media_type": "image", "media_size": "16-9", "bleed_desktop": "inline_start" }
        },
        "container-card": {
          "type": "media",
          "settings": { "media_type": "image", "media_size": "16-9", "container_style": "card" }
        },
        "scheme-override": {
          "type": "media",
          "settings": {
            "media_type": "image",
            "media_size": "16-9",
            "custom_color_scheme": true,
            "color_scheme": "scheme-2"
          }
        },
        "width-capped": {
          "type": "media",
          "settings": { "media_type": "image", "media_size": "16-9", "content_width": "reading" }
        },
        "with-spacing": {
          "type": "media",
          "settings": {
            "media_type": "image",
            "media_size": "16-9",
            "mobile_margin_block_start": 16,
            "desktop_margin_block_start": 64
          }
        },
        "overlay-default": {
          "type": "media",
          "blocks": {
            "t": { "type": "title", "settings": { "tag": "h3", "content": "Hero default (bottom-start)" } }
          },
          "block_order": ["t"],
          "settings": { "media_type": "image", "media_size": "16-9" }
        },
        "align-center": {
          "type": "media",
          "blocks": {
            "t": { "type": "title", "settings": { "tag": "h3", "content": "Centered overlay" } }
          },
          "block_order": ["t"],
          "settings": {
            "media_type": "image",
            "media_size": "16-9",
            "horizontal_alignment": "center",
            "vertical_alignment": "center"
          }
        },
        "align-end": {
          "type": "media",
          "blocks": {
            "t": { "type": "title", "settings": { "tag": "h3", "content": "End-start overlay" } }
          },
          "block_order": ["t"],
          "settings": {
            "media_type": "image",
            "media_size": "16-9",
            "horizontal_alignment": "end",
            "vertical_alignment": "start"
          }
        },
        "gap-zero": {
          "type": "media",
          "blocks": {
            "t": { "type": "title", "settings": { "tag": "h3", "content": "Gap-zero overlay" } },
            "b": { "type": "button", "settings": { "content": "No-gap CTA", "link": "/" } }
          },
          "block_order": ["t", "b"],
          "settings": { "media_type": "image", "media_size": "16-9", "gap": 0, "vertical_alignment": "center" }
        },
        "grouped-overlay": {
          "type": "media",
          "blocks": {
            "g": {
              "type": "group",
              "blocks": {
                "gt": { "type": "title", "settings": { "tag": "h3", "content": "Grouped overlay" } },
                "gb": { "type": "button", "settings": { "content": "Group CTA", "link": "/" } }
              },
              "block_order": ["gt", "gb"],
              "settings": { "direction": "row", "gap": 16, "stack_below": "none" }
            }
          },
          "block_order": ["g"],
          "settings": { "media_type": "image", "media_size": "16-9", "vertical_alignment": "center" }
        }
      },
      "block_order": [
        "image-placeholder",
        "size-ratio-11",
        "size-relative-half",
        "size-fill",
        "type-video",
        "fit-contain",
        "overlay-tint",
        "bleed-both",
        "bleed-start",
        "container-card",
        "scheme-override",
        "width-capped",
        "with-spacing",
        "overlay-default",
        "align-center",
        "align-end",
        "gap-zero",
        "grouped-overlay"
      ],
      "settings": {}
    }
  },
  "order": ["main"]
}
