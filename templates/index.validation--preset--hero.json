{
  "sections": {
    "main": {
      "type": "validation--preset--hero",
      "blocks": {
        "hero-media": {
          "type": "media",
          "blocks": {
            "hero-title": {
              "type": "title",
              "settings": {
                "tag": "h1",
                "content": "Built for the long haul",
                "text_align": "center"
              }
            },
            "hero-body": {
              "type": "richtext",
              "settings": {
                "content": "<p>A metaobject-driven theme you compose, not a template you fight. This overlay inherits the media block's scheme-3 tokens (light on dark), not the section's scheme-1.</p>",
                "text_align": "center",
                "content_width": "reading"
              }
            },
            "hero-cta": {
              "type": "button",
              "settings": {
                "content": "Get started",
                "link": "/"
              }
            }
          },
          "block_order": ["hero-title", "hero-body", "hero-cta"],
          "settings": {
            "media_type": "image",
            "image": "shopify://shop_images/landscape.png",
            "media_size": "16-9",
            "bleed_desktop": "both",
            "bleed_mobile": "both",
            "overlay_color": "rgba(0, 0, 0, 0.45)",
            "custom_color_scheme": true,
            "color_scheme": "scheme-3",
            "horizontal_alignment": "center",
            "vertical_alignment": "center",
            "gap": 24
          }
        }
      },
      "block_order": ["hero-media"],
      "settings": {
        "color_scheme": "scheme-1"
      }
    }
  },
  "order": ["main"]
}
