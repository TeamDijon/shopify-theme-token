{% # Validation - Block - Group v1.0.0 %}

{% comment %}
  Block-validation harness for `group` (a container that nests
  `@theme` children). The JSON template at
  `templates/index.validation--primitive--group.json` bakes the test
  matrix; the section just renders them in a labelled list via
  `validation--block-labels`.

  Diagnostic intent:
  1. Direction modifier (column / row) emits the right flex axis.
  2. `stack-below:<bp>` modifier triggers a container-query swap to
     column direction when the group itself is narrower than the
     breakpoint (40rem / 60rem / 80rem). Resize the page to validate.
  3. Horizontal/vertical alignment + gap apply correctly per direction.
  4. color_scheme override emits `color-scheme:<id>` for inner blocks
     to inherit.

  Reachable only at /?view=validation--primitive--group.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Block: group</h1>
    <p>
      Matrix in
      <code>templates/index.validation--primitive--group.json</code>. Each entry is a group with three child buttons.
      Variants exercise direction (column / row), horizontal/vertical alignment, gap, the stack-below container query
      (resize to validate), and the color-scheme override. content_width is metaobject-typed and tested on its dedicated
      page.
    </p>
  </header>

  {% if section.blocks.size > 0 %}
    <div class="block-validation-suite">
      {% content_for 'blocks' %}
    </div>

    {% render 'validation--block-labels', section: section %}
  {% else %}
    <p class="block-validation-suite__empty">No blocks declared in the template.</p>
  {% endif %}
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Block: group",
  "tag": "section",
  "class": "shopify-section--validation--primitive--group",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--primitive--group {
      token-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .block-validation-suite {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        padding-block-start: 1.5rem;
      }

      .block-validation-suite__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      /* Outline the group wrapper so the layout bounds + alignment
         behaviour is observable. Inset padding so children don't sit
         flush against the dashed line. */
      .block-validation-suite > .shopify-block--group {
        position: relative;
        padding: 1rem;
        outline: 1px dashed rgba(0, 0, 0, 0.18);
        outline-offset: -1px;
      }

      .block-validation-suite > .shopify-block--group::before {
        content: var(--block-label, '');
        position: absolute;
        inset-block-end: calc(100% + 0.375rem);
        inset-inline-start: 0;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
        font-weight: 600;
        opacity: 0.7;
      }
    }
  }
{% endstylesheet %}
