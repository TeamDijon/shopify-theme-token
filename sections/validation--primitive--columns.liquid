{% # Validation - Block - Columns v1.1.0 %}

{% comment %}
  Changelog
  - v1.1.0 — render columns as direct children of `<token-section>` (drop the `.block-validation-suite` flex wrapper) + base `--block-rhythm: lg` on the section, so per-block top-margin overrides paint, bleed escapes the section grid, and the page is production-faithful. Track-outline selector follows the snippet's inner wrapper to `> token-layout` (was the dead `__inner` class). Label selectors target `token-section >`. Per `validation.md` § Harness layout.
  - v1.0.1 — target the new `.shopify-block--columns__inner > *` for column-track outlines after the snippet moved its grid to an inner wrapper
  - v1.0.0 — initial

  Block-validation harness for `columns`. The JSON template at
  `templates/index.validation--primitive--columns.json` bakes the test
  matrix; the section just renders them in a labelled list via
  `validation--block-labels`.

  Diagnostic intent:
  1. Each `columns` value (2 / 3 / 4 / 1-2 / 2-1 / 1-3 / 3-1) emits the
     right modifier and lays children out in the expected grid.
  2. `stack-below` collapses to single column below the breakpoint —
     same container-query mechanism the group block uses (resize to
     validate; 80 never reaches the harness width, proving @container
     vs @media).
  3. Sticky-track pins the named track; stack-below collapse disables it.
  4. Vertical alignment, gap, bleed, container_style, color-scheme band,
     content_width cap, recursion, and top-spacing overrides.

  Reachable only at /?view=validation--primitive--columns.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Block: columns</h1>
    <p>
      Matrix in
      <code>templates/index.validation--primitive--columns.json</code>. Each entry exercises one ratio or behavior —
      column ratios, stack-below (resize to validate; 80 never reaches the harness width), sticky-track, vertical
      alignment, gap, bleed, container_style, the color-scheme band, content_width cap, recursion, and top-spacing.
      Children are richtext blocks labelling each track.
    </p>
  </header>

  {% if section.blocks.size > 0 %}
    {% content_for 'blocks' %}

    {% render 'validation--block-labels', section: section %}
  {% else %}
    <p class="validation__empty">No blocks declared in the template.</p>
  {% endif %}
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Block: columns",
  "tag": "section",
  "class": "shopify-section--validation--primitive--columns",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--primitive--columns {
      token-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;

        /* Production-faithful baseline rhythm; per-block overrides replace it
           via the theme-root rhythm rule in layer-theme.css. */
        --block-rhythm: var(--spacing-lg);
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .validation__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      /* Outline the columns wrapper so column boundaries + alignment are
         observable (outline doesn't affect layout — no fidelity cost). */
      token-section > .shopify-block--columns {
        position: relative;
        outline: 1px dashed rgba(0, 0, 0, 0.18);
        outline-offset: -1px;
      }

      token-section > .shopify-block--columns::before {
        content: var(--block-label, '');
        position: absolute;
        inset-block-end: calc(100% + 0.375rem);
        inset-inline-start: 0;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
        font-weight: 600;
        opacity: 0.7;
      }

      /* Faint background + outline on each grid track (the children of the
         inner <token-layout>) so individual tracks are visible. */
      token-section > .shopify-block--columns > token-layout > * {
        background-color: rgba(0, 0, 0, 0.03);
        outline: 1px dashed rgba(0, 0, 0, 0.12);
        padding: 0.5rem;
      }
    }
  }
{% endstylesheet %}
