{% # Exploration: Hero (no bleed) v1.0.0 %}

{% render 'exploration--canvas', section: section %}

{% schema %}
{
  "name": "Hero, no bleed",
  "tag": "section",
  "class": "shopify-section--exploration",
  "blocks": [
    { "type": "exploration-media" },
    { "type": "exploration-text" },
    { "type": "exploration-columns" }
  ],
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "No-bleed hero + content in gutter" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Variant 2 — media stays in canvas gutter on both desktop + mobile, sibling text below same. Baseline contrast to variant 1." }
  ]
}
{% endschema %}
