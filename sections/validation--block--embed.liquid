{% # Validation - Block - Embed v1.0.0 %}

{% comment %}
  Block-validation harness for `embed`. The JSON template at
  `templates/index.validation--block--embed.json` bakes the test
  matrix; the section just renders them in a labelled list via
  `validation--block-labels`.

  Diagnostic intent:
  1. The URL parser resolves each supported provider URL pattern to the
     right embed_url and emits the matching `provider:youtube` /
     `provider:vimeo` modifier. Each entry's data-modifiers attribute
     surfaces the resolution.
  2. Blank or unparseable URLs fall through to the placeholder branch
     (Shopify's `placeholder_svg_tag`).
  3. Top-spacing settings apply at the right breakpoint.

  Variant sizing (`media_size`) is metaobject-typed and tested on the
  metaobject validation page; default render is 16/9 aspect ratio.

  Reachable only at /?view=validation--block--embed.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<theme-section>
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Block: embed</h1>
    <p>
      Matrix in
      <code>templates/index.validation--block--embed.json</code>. Each
      entry below exercises one URL shape the embed snippet recognizes
      (YouTube watch / short / shorts / embed; Vimeo regular / unlisted /
      player). The label below each iframe is the block id; data-modifiers
      attribute surfaces the resolved provider. Blank or unparseable URLs
      render the placeholder SVG.
    </p>
  </header>

  {% if section.blocks.size > 0 %}
    <div class="block-validation-suite">
      {% content_for 'blocks' %}
    </div>

    {% render 'validation--block-labels', section: section %}
  {% else %}
    <p class="block-validation-suite__empty">No blocks declared in the template.</p>
  {% endif %}
</theme-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Block: embed",
  "tag": "section",
  "class": "shopify-section--validation--block--embed",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--block--embed {
      theme-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .block-validation-suite {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        padding-block-start: 1.5rem;
      }

      .block-validation-suite__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      .block-validation-suite > .shopify-block--embed {
        position: relative;
        max-inline-size: 32rem;
      }

      .block-validation-suite > .shopify-block--embed::before {
        content: var(--block-label, '');
        position: absolute;
        inset-block-end: calc(100% + 0.375rem);
        inset-inline-start: 0;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
        font-weight: 600;
        opacity: 0.7;
        z-index: 1;
      }
    }
  }
{% endstylesheet %}
