{% # Section v1.2.0 %}

{% comment %}
  Changelog
  - v1.2.0 — replace `@theme` blocks wildcard with an explicit whitelist of the 9 shipped L1 blocks (+ `@app`) per the block-whitelisting convention in `composition-strategy.md`
  - v1.1.0 — add `block_rhythm` setting (spacing metaobject) + emit `--block-rhythm-{mobile,desktop}` variables for the inter-block margin rule in `core.css`
  - v1.0.0 — initial
{% endcomment %}

{% liquid
  assign content_width = section.settings.content_width
  assign block_rhythm = section.settings.block_rhythm
  assign base_selector = 'shopify-section-' | append: section.id
%}

<theme-section data-modifiers="color-scheme:{{ section.settings.color_scheme }}">
  {% content_for 'blocks' %}
</theme-section>

{% capture dynamic_style %}
  {% if content_width and content_width != blank %}
    --content-width: {{ content_width.width.value }}px;
  {% endif %}
  {% if block_rhythm and block_rhythm != blank %}
    --block-rhythm-mobile: {{ block_rhythm.mobile_value.value }}px;
    --block-rhythm-desktop: {{ block_rhythm.desktop_value.value }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "t:sections.section.name",
  "tag": "section",
  "class": "shopify-section--section",
  "blocks": [
    { "type": "spacer" },
    { "type": "separator" },
    { "type": "title" },
    { "type": "richtext" },
    { "type": "button" },
    { "type": "media" },
    { "type": "embed" },
    { "type": "group" },
    { "type": "columns" },
    { "type": "@app" }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.section.settings.layout.content"
    },
    {
      "type": "metaobject",
      "metaobject_type": "content_width",
      "id": "content_width",
      "label": "t:sections.section.settings.content_width.label",
      "info": "t:sections.section.settings.content_width.info"
    },
    {
      "type": "metaobject",
      "metaobject_type": "spacing",
      "id": "block_rhythm",
      "label": "t:sections.section.settings.block_rhythm.label",
      "info": "t:sections.section.settings.block_rhythm.info"
    },
    {
      "type": "header",
      "content": "t:sections.section.settings.appearance.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.section.settings.color_scheme.label",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:sections.section.presets.section.name"
    }
  ]
}
{% endschema %}
