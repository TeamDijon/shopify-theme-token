{% # Section v1.0.0 %}

{% comment %}
  {% liquid
    assign content_width = section.settings.content_width
    assign base_selector = 'shopify-section-' | append: section.id
  %}

  <token-section data-modifiers='color-scheme:{{ section.settings.color_scheme }}'>
    {% content_for 'blocks' %}
  </token-section>

  {% capture dynamic_style %}
    {% if content_width and content_width != blank %}
      --content-width: {{ content_width.width.value }}px;
    {% endif %}
  {% endcapture %}
  {% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
{% endcomment %}

{% schema %}
{
  "name": "Section",
  "tag": "section",
  "blocks": [{ "type": "@theme" }, { "type": "@app" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "metaobject",
      "metaobject_type": "content_width",
      "id": "content_width",
      "label": "Content width",
      "info": "Leave blank for full width"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Section"
    }
  ]
}
{% endschema %}
