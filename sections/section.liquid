    },
    {
      "type": "checkbox",
      "id": "custom_color_scheme",
      "label": "t:sections.section.settings.custom_color_scheme.label",
      "info": "t:sections.section.settings.custom_color_scheme.info",
      "default": false
    },
    {
      "type": "color_scheme",
