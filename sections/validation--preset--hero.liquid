{% # Validation - Section - Hero v1.0.0 %}

{% comment %}
  Section-level composition validation for the "hero" pattern: a single
  media block with bleed, overlaid title + button rendering inside the
  block's <media-contents> overlay. Exercises:

  - The media block's bleed branch (escapes the section gutter to full
    viewport width via `inline-size: 100dvw; margin-inline: calc(50% -
    50dvw)`).
  - <media-contents> overlay positioning (absolute inside the media
    wrapper) with horizontal/vertical alignment.
  - Color-scheme override on the media block — the overlay's child
    title + button pick up scheme-2 tokens, not the section's scheme-1.
  - Overlay tint paints over the placeholder SVG (without an actual
    image asset).
  - Focus-ring inset adjustment on a focusable child inside an
    overflow:hidden wrapper (tab into the button to validate).

  Reachable only at /?view=validation--preset--hero.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign color_scheme = section.settings.color_scheme | default: 'scheme-1'
  assign base_selector = 'shopify-section-' | append: section.id
%}

<theme-section data-modifiers="theme-root,color-scheme:{{ color_scheme }}">
  {% render 'validation--breadcrumb' %}

  {% content_for 'blocks' %}
</theme-section>

{% capture dynamic_style %}
  --block-rhythm-mobile: 0;
  --block-rhythm-desktop: 0;
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Section: hero",
  "tag": "section",
  "class": "shopify-section--validation--preset--hero",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--preset--hero theme-section {
      display: block;
      max-inline-size: 80rem;
      margin-inline: auto;
      padding-block: 1.5rem;
      padding-inline: 1.5rem;
    }
  }
{% endstylesheet %}
