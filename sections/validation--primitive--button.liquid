{% # Validation - Block - Button v1.1.0 %}

{% comment %}
  Changelog
  - v1.1.0 — render blocks as direct children of `<token-section>` (drop the `.block-validation-suite` flex wrapper); the column layout + base `--block-rhythm: lg` move onto the section itself, so per-block top-margin overrides paint via the theme-root rhythm rule and the page is production-faithful. Per `validation.md` § Harness layout.

  Block-validation harness for `button`. The JSON template at
  `templates/index.validation--primitive--button.json` bakes the test
  matrix; the section just renders them in a labelled list via
  `validation--block-labels`.

  Diagnostic intent:
  1. `link` blank → renders `<button type="button">`; `link` set →
     renders `<a href="...">`.
  2. `open_in_new_tab: true` on a linked button appends
     `target="_blank" rel="noopener noreferrer"` and a screen-reader-only
     "(opens in new tab)" string.
  3. Top-spacing settings apply at the right breakpoint.

  Variant styling (`button_style`) is exercised on the metaobject
  validation page (`?view=validation--substrate--button-style`); icon
  and content_width settings are also metaobject-typed.

  Reachable only at /?view=validation--primitive--button.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Block: button</h1>
    <p>
      Matrix in
      <code>templates/index.validation--primitive--button.json</code>. Each entry below is one block instance, labelled
      by its block id. The matrix exercises the snippet's tag-emission branches (link → <code>&lt;a&gt;</code> vs
      no-link → <code>&lt;button&gt;</code>), the new-tab branch, and top-margin application. Variant styling
      (button_style) is tested on its <a href="?view=validation--substrate--button-style">metaobject page</a>.
    </p>
  </header>

  {% if section.blocks.size > 0 %}
    {% content_for 'blocks' %}

    {% render 'validation--block-labels', section: section %}
  {% else %}
    <p class="validation__empty">No blocks declared in the template.</p>
  {% endif %}
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Block: button",
  "tag": "section",
  "class": "shopify-section--validation--primitive--button",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--primitive--button {
      token-section {
        /* Buttons are inline-flex; a column flow stacks them (one per row,
           flush-start) so the theme-root rhythm rule's margin-block-start
           paints between them — mirroring how grid auto-placement stacks
           button blocks in production. */
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;

        /* Production-faithful baseline rhythm; per-block overrides replace it
           via the theme-root rhythm rule in layer-theme.css. */
        --block-rhythm: var(--spacing-lg);
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }

        a {
          color: var(--color-role-primary);
          text-decoration: underline;
          text-underline-offset: 0.2em;
        }
      }

      .validation__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      /* Float the DOM-id label above each button (inline-flex blocks). */
      token-section > .shopify-block--button {
        position: relative;
      }

      /* Buttons use white text by default; override for the label so it
         contrasts with the page rather than inheriting button-fg. */
      token-section > .shopify-block--button::before {
        content: var(--block-label, '');
        position: absolute;
        inset-block-end: calc(100% + 0.375rem);
        inset-inline-start: 0;
        color: var(--color-role-foreground, #1a1a1a);
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
        font-weight: 600;
        opacity: 0.7;
        white-space: nowrap;
      }
    }
  }
{% endstylesheet %}
