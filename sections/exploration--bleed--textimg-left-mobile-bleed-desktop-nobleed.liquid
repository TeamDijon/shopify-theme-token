{% # Exploration: T+I L mob bleed only v1.0.0 %}

{% render 'exploration--canvas', section: section %}

{% schema %}
{
  "name": "T+I L mob bleed only",
  "tag": "section",
  "class": "shopify-section--exploration",
  "blocks": [
    { "type": "exploration-media" },
    { "type": "exploration-text" },
    { "type": "exploration-columns" }
  ],
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Text + image (left), mobile bleed, no desktop bleed" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Variant 7 — columns 1:1 (equal split). Media in canvas gutter on desktop (no bleed). On mobile (stacked), media bleeds both sides. Common editorial pattern: contained alongside on desktop, expansive on mobile." }
  ]
}
{% endschema %}
