{% # Validation hub v1.1.0 %}

{% comment %}
  Changelog
  - v1.1.0 — align layout with the per-page validation container (max-inline-size, padding, flush-left list); drop disc bullets and underline-by-default links so the table-of-contents reads as a uniform column.
  - v1.0.0 — initial

  Hub page for the validation suite. Lists every validation section by layer.
  Reachable only at /?view=validation — never linked from production templates.
  See `.context/docs/validation.md` for the full convention.
{% endcomment %}

<token-section data-modifiers="theme-root">
  <header class="validation-hub__intro">
    <h1>Validation</h1>
    <p>
      Visual + integration test pages for metaobjects, blocks, and section compositions. Reachable via querystring only;
      never linked from production. See <code>.context/docs/validation.md</code>.
    </p>
  </header>

  <section class="validation-hub__layer">
    <header class="validation-hub__layer-head">
      <h2>Metaobjects</h2>
      <span class="validation-hub__count">8</span>
    </header>
    <ul class="validation-hub__list">
      <li><a href="?view=validation--substrate--button-style">Button style</a></li>
      <li><a href="?view=validation--substrate--container-style">Container style</a></li>
      <li><a href="?view=validation--substrate--content-width">Content width</a></li>
      <li><a href="?view=validation--substrate--icon">Icon</a></li>
      <li><a href="?view=validation--substrate--media-size">Media size</a></li>
      <li><a href="?view=validation--substrate--spacing">Spacing</a></li>
      <li><a href="?view=validation--substrate--text-style">Text style</a></li>
      <li><a href="?view=validation--substrate--theme-color">Theme color</a></li>
    </ul>
  </section>

  <section class="validation-hub__layer">
    <header class="validation-hub__layer-head">
      <h2>Blocks</h2>
      <span class="validation-hub__count">9</span>
    </header>
    <ul class="validation-hub__list">
      <li><a href="?view=validation--primitive--button">Button</a></li>
      <li><a href="?view=validation--primitive--columns">Columns</a></li>
      <li><a href="?view=validation--primitive--embed">Embed</a></li>
      <li><a href="?view=validation--primitive--group">Group</a></li>
      <li><a href="?view=validation--primitive--media">Media</a></li>
      <li><a href="?view=validation--primitive--richtext">Richtext</a></li>
      <li><a href="?view=validation--primitive--separator">Separator</a></li>
      <li><a href="?view=validation--primitive--spacer">Spacer</a></li>
      <li><a href="?view=validation--primitive--title">Title</a></li>
    </ul>
  </section>

  <section class="validation-hub__layer">
    <header class="validation-hub__layer-head">
      <h2>Compositions</h2>
      <span class="validation-hub__count">4</span>
    </header>
    <ul class="validation-hub__list">
      <li><a href="?view=validation--preset--content">Content (title + richtext + button)</a></li>
      <li><a href="?view=validation--preset--columns-features">Columns features</a></li>
      <li><a href="?view=validation--preset--cta-banner">CTA banner</a></li>
      <li><a href="?view=validation--preset--hero">Hero (media + overlay)</a></li>
    </ul>
  </section>
</token-section>

{% schema %}
{
  "name": "Validation hub",
  "tag": "section",
  "class": "shopify-section--validation",
  "settings": []
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation {
      token-section {
        display: block;
        max-inline-size: 80rem;
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation-hub__intro {
        margin-block-end: 2.5rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .validation-hub__layer {
        margin-block-end: 2rem;

        &:last-child {
          margin-block-end: 0;
        }
      }

      .validation-hub__layer-head {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        margin-block-end: 0.75rem;
        padding-block-end: 0.5rem;
        border-block-end: 1px solid rgba(0, 0, 0, 0.12);

        h2 {
          margin: 0;
        }
      }

      .validation-hub__count {
        font-family: ui-monospace, monospace;
        font-size: 0.875rem;
        opacity: 0.55;
      }

      .validation-hub__list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
      }

      .validation-hub__list li {
        margin: 0;
      }

      .validation-hub__list a {
        display: block;
        padding-block: 0.375rem;
        color: inherit;
        text-decoration: none;

        &:hover,
        &:focus-visible {
          color: var(--color-role-primary);
          text-decoration: underline;
          text-underline-offset: 0.2em;
        }
      }
    }
  }
{% endstylesheet %}
