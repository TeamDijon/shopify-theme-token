{% # Validation - Text style v1.1.1 %}

{% comment %}
  Changelog
  - v1.1.1 — schema `name` shortened to "Text style" (drop "Validation - " prefix; the URL path is the source of truth and the prefix bumped longer names past Shopify's 25-char schema-name limit)
  - v1.1.0 — render `validation--breadcrumb` at the top so the developer can navigate back to the hub
  - v1.0.0 — initial

  Visual test page for the `text_style` metaobject. Iterates every entry,
  surfaces the raw metaobject fields as a metadata strip, and renders a
  pangram specimen with `data-text-style="<handle>"` so the actual
  consumption path (CSS custom properties → cascade selector) is what's
  tested rather than the metaobject values in isolation.

  Diagnostic intent:
  1. Each handle resolves through `[data-text-style="<handle>"]`, which
     `utility--css-variables.liquid` emits as the consumption selector.
  2. The rendered specimen matches the metadata strip — if the strip
     says weight 700 but the specimen looks light, the metaobject and
     CSS pipeline disagree.
  3. Heading handles (h1..h6) are sampled on a `<p>` here to isolate
     them from the bare-element selector (which auto-binds h1..h6 in
     normal page flow).

  Reachable only at /?view=validation--substrate--text-style.
  See `.context/docs/validation.md` for the validation-suite convention.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Text style</h1>
    <p>
      Source: <code>metaobjects.text_style.values</code>. Consumed via
      <code>[data-text-style="&lt;handle&gt;"]</code> (and on bare
      <code>h1</code>–<code>h6</code> when the handle matches). Each row
      lists the raw metaobject fields and renders a pangram specimen so
      a mismatch between metadata and rendered output flags a broken
      pipeline.
    </p>
  </header>

  <ol class="text-style-suite">
    {% for text_style in metaobjects.text_style.values %}
      {% liquid
        assign handle = text_style.system.handle
        assign family = text_style.font_family.value.name.value | default: '—'
        assign fallback = text_style.font_fallback_family.value | default: 'sans'
        assign mobile_size = text_style.mobile_font_size.value | default: 0
        assign desktop_size = text_style.desktop_font_size.value | default: mobile_size
        assign weight = text_style.weight.value | default: '400'
        assign line_height = text_style.line_height.value | default: 1.5
        assign letter_spacing = text_style.letter_spacing.value | default: 0
        assign font_style = text_style.font_style.value | default: 'normal'
        assign uppercase = text_style.uppercase.value
        assign underline = text_style.underline.value
      %}

      <li class="text-style-row">
        {% liquid
          assign mobile_display = mobile_size | round
          assign desktop_display = desktop_size | round
          assign letter_spacing_display = letter_spacing | round: 2
        %}
        <header class="text-style-row__head">
          <code class="text-style-row__handle">{{ handle }}</code>
          <code class="text-style-row__family">{{ family }} / {{ fallback }}</code>
          {% if mobile_display == desktop_display %}
            <span class="text-style-row__metric">{{ mobile_display }}px</span>
          {% else %}
            <span class="text-style-row__metric">{{ mobile_display }}/{{ desktop_display }}px</span>
          {% endif %}
          <span class="text-style-row__metric">weight {{ weight }}</span>
          <span class="text-style-row__metric">leading {{ line_height }}</span>
          {% if letter_spacing_display != 0 %}
            <span class="text-style-row__metric">tracking {{ letter_spacing_display }}px</span>
          {% endif %}
          {% if font_style != 'normal' %}
            <span class="text-style-row__flag">{{ font_style }}</span>
          {% endif %}
          {% if uppercase %}
            <span class="text-style-row__flag">uppercase</span>
          {% endif %}
          {% if underline %}
            <span class="text-style-row__flag">underline</span>
          {% endif %}
        </header>

        <p class="text-style-row__specimen" data-text-style="{{ handle }}">
          The quick brown fox jumps over the lazy dog. AaBbCc 0123456789
        </p>
      </li>
    {% else %}
      <li class="text-style-suite__empty">
        No <code>text_style</code> metaobject entries defined.
      </li>
    {% endfor %}
  </ol>
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Text style",
  "tag": "section",
  "class": "shopify-section--validation--substrate--text-style",
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--substrate--text-style {
      token-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .text-style-suite {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .text-style-suite__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      .text-style-row {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0.5rem;
      }

      .text-style-row__head {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.375rem 0.75rem;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
      }

      .text-style-row__handle {
        font-weight: 600;
      }

      .text-style-row__family {
        opacity: 0.65;
      }

      .text-style-row__metric {
        opacity: 0.55;
      }

      .text-style-row__flag {
        padding-block: 0.125rem;
        padding-inline: 0.375rem;
        border: 1px solid rgba(0, 0, 0, 0.18);
        border-radius: 0.25rem;
        font-size: 0.6875rem;
      }

      .text-style-row__specimen {
        margin: 0;
        overflow-wrap: anywhere;
      }
    }
  }
{% endstylesheet %}
