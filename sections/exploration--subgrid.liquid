{% stylesheet %}
  @layer components {
    .shopify-section--exploration--subgrid {
      theme-section {
        padding-block: 2rem 4rem;
      }

      .subgrid-intro {
        margin-block-end: 2.5rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.8;
          margin-block: 0.5rem 0;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.9em;
          background: rgba(0, 0, 0, 0.06);
          padding-inline: 0.25rem;
          border-radius: 0.25rem;
        }
      }

      .case-label {
        margin-block-start: 3rem;
        margin-block-end: 0.75rem;
        padding-block-end: 0.5rem;
        border-block-end: 1px solid rgba(0, 0, 0, 0.12);

        h2 {
          font-size: 1.25rem;
          margin-block: 0 0.25rem;
        }

        p {
          font-size: 0.875rem;
          opacity: 0.8;
          margin-block: 0;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.9em;
          background: rgba(0, 0, 0, 0.06);
          padding-inline: 0.2rem;
          border-radius: 0.2rem;
        }
      }

      .demo {
        background: rgba(0, 0, 0, 0.06);
        padding: 1.5rem;
        border-radius: 0.5rem;
        outline: 2px dashed rgba(0, 0, 0, 0.25);
        outline-offset: -2px;
        font-family: ui-monospace, monospace;
        font-size: 0.875rem;
      }

      .demo--bleed,
      .demo--content {
        text-align: center;
      }

      .demo--bleed {
        background: rgba(0, 122, 255, 0.12);
        outline-color: rgba(0, 122, 255, 0.5);
      }

      .demo--hero {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1rem;

        @media (width < 48rem) {
          grid-template-columns: 1fr;
        }
      }

      .demo--hero-mirror {
        grid-template-columns: 1fr 2fr;

        @media (width < 48rem) {
          grid-template-columns: 1fr;
        }
      }

      .demo__media {
        background: rgba(0, 0, 0, 0.18);
        padding: 2rem;
        border-radius: 0.25rem;
        text-align: center;
        min-block-size: 8rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .demo__copy {
        padding-inline: 0.5rem;

        h3 {
          margin-block: 0 0.5rem;
        }

        p {
          margin-block: 0;
          font-family: inherit;
        }
      }

      .demo--two-track,
      .demo--three-track {
        display: grid;
        gap: 1rem;
      }

      .demo--two-track {
        grid-template-columns: 1fr 1fr;

        @media (width < 48rem) {
          grid-template-columns: 1fr;
        }
      }

      .demo--three-track {
        grid-template-columns: 1fr 1fr 1fr;

        @media (width < 48rem) {
          grid-template-columns: 1fr;
        }
      }

      .demo__track {
        background: rgba(0, 0, 0, 0.12);
        padding: 1rem;
        border-radius: 0.25rem;
        text-align: center;
      }

      .demo__nested-group {
        background: rgba(255, 100, 0, 0.18);
        outline: 1px dashed rgba(255, 100, 0, 0.5);
        outline-offset: -1px;
      }
    }
  }
{% endstylesheet %}
