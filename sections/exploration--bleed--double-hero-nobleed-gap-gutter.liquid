    { "type": "textarea", "id": "description", "label": "Description", "default": "Variant 4 — columns stays in canvas (no bleed), gap = 48px (roughly matching the canvas-to-viewport gutter at typical viewports). Two media children sized 16:9 within their tracks. Tests how a non-bleeding gap-aware composition reads." }
  ]
}
{% endschema %}
