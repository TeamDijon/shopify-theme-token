{% # Exploration: T+I R desk bleed only v1.0.0 %}

{% render 'exploration--canvas', section: section %}

{% schema %}
{
  "name": "T+I R desk bleed only",
  "tag": "section",
  "class": "shopify-section--exploration",
  "blocks": [
    { "type": "exploration-media" },
    { "type": "exploration-text" },
    { "type": "exploration-columns" }
  ],
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Text + image (right), no mobile bleed, desktop bleed" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Variant 6 — columns 1:2 (image wider, on right). Media bleeds inline-end on desktop (escapes right to viewport edge). On mobile (stacked), media stays in canvas gutter (no mobile bleed). Text always in gutter." }
  ]
}
{% endschema %}
