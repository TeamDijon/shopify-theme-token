{% # Validation - Block - Separator v2.0.0 %}

{% comment %}
  Changelog
  - v2.0.0 — token-section is now the real production theme-root grid (drop the `display: block` override + the `.block-validation-suite` flex wrapper, so the bleed grid + block-rhythm cascade apply). Harness chrome + the layout-neutral outline/label indicator move to the shared `validation--harness-styles` snippet. Matrix expanded: `content_width` + `line_color` now baked by metaobject handle (the same handle-reference form `index.json` uses for spacing) — no longer "JSON-portable settings only". Per `validation.md` § Harness layout.
  - v1.0.1 — drop the local `inline-size: 100%` workaround now that the snippet sets it itself
  - v1.0.0 — initial

  Block-validation harness for `separator`. The JSON template at
  `templates/index.validation--primitive--separator.json` bakes the test
  matrix as block instances; the section renders them directly as children
  of the theme-root grid, labelled via `validation--block-labels`.

  Diagnostic intent:
  1. content_width cap + centering (narrow / medium handles).
  2. line_color resolution (primary / accent handles) vs the
     --color-role-border default when blank.
  3. Top-spacing overrides (mobile / desktop), zero-emission discipline:
     a 0 value falls through to the section --block-rhythm.

  Reachable only at /?view=validation--primitive--separator.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Block: separator</h1>
    <p>
      Matrix in
      <code>templates/index.validation--primitive--separator.json</code>. Each entry exercises one facet —
      <code>content_width</code> cap + centering, <code>line_color</code> resolution (vs the
      <code>--color-role-border</code> default), and top-spacing overrides (resize across 768px; a 0 value falls through
      to the section rhythm). The metaobject settings are baked by handle.
    </p>
  </header>

  {% if section.blocks.size > 0 %}
    {% content_for 'blocks' %}

    {% render 'validation--block-labels', section: section %}
  {% else %}
    <p class="validation__empty">No blocks declared in the template.</p>
  {% endif %}
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
{% render 'validation--harness-styles' %}

{% schema %}
{
  "name": "Block: separator",
  "tag": "section",
  "class": "shopify-section--validation--primitive--separator",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}
