{% # Validation - Container style v1.0.0 %}

{% comment %}
  Visual test page for the `container_style` metaobject.

  Current state: the container/group block isn't implemented yet, so
  there's nothing to render against. This page is intentionally sparse —
  it lists the metaobject inventory and the modifier string the future
  block will emit. Once the container block lands, expand this section
  to render a real container element per entry (`<div data-modifiers=
  "container-style:<handle>">…</div>`), exercising the pipeline the way
  validation--substrate--button-style does for buttons.

  Reachable only at /?view=validation--substrate--container-style.
  See `.context/docs/validation.md` for the validation-suite convention.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Container style</h1>
    <p>
      Source: <code>metaobjects.container_style.values</code>. Future
      consumption: <code>[data-modifiers*="container-style:&lt;handle&gt;"]</code>
      on the container/group block (not yet implemented). Each row shows
      the handle and the modifier string the block will emit. When the
      block ships, expand this page to render a real container per entry.
    </p>
  </header>

  <ol class="container-style-suite">
    {% for container_style in metaobjects.container_style.values %}
      {% liquid
        assign handle = container_style.system.handle
        assign name = container_style.name.value | default: '—'
      %}

      <li class="container-style-row">
        <header class="container-style-row__head">
          <code class="container-style-row__handle">{{ handle }}</code>
          <span class="container-style-row__name">{{ name }}</span>
          <code class="container-style-row__modifier">data-modifiers="container-style:{{ handle }}"</code>
        </header>
      </li>
    {% else %}
      <li class="container-style-suite__empty">
        No <code>container_style</code> metaobject entries defined.
      </li>
    {% endfor %}
  </ol>
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Container style",
  "tag": "section",
  "class": "shopify-section--validation--substrate--container-style",
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--substrate--container-style {
      token-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .container-style-suite {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .container-style-suite__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      .container-style-row {
        padding: 0.875rem 1rem;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0.5rem;
      }

      .container-style-row__head {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.375rem 0.75rem;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
      }

      .container-style-row__handle {
        font-weight: 600;
      }

      .container-style-row__name {
        font-family: inherit;
        opacity: 0.75;
      }

      .container-style-row__modifier {
        opacity: 0.55;
        margin-inline-start: auto;
      }
    }
  }
{% endstylesheet %}
