{% # Validation - Snippet - Image v1.0.1 %}

{% comment %}
  Changelog
  - v1.0.1 — remove the `validation--breadcrumb` render (linked the retired hub); the template now generate-and-drops from the colocated `snippets/image.validation.json` source

  Snippet-validation harness for `image` (a sub-component snippet — no block, so
  the page renders `{% render 'image' %}` directly rather than a block matrix).
  The two source images come from store Files (seeded by
  `.scripts/seed-validation-assets.mjs`), referenced by handle in the JSON
  template via image_picker settings → real image objects for image_url/image_tag.

  Diagnostic intent: srcset ladder, <picture> art-direction switch, loading /
  fetchpriority / sizes / preload knobs. Each case is tagged `data-case=<id>`.

  Reachable only at /?view=validation.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image
%}

<token-section data-modifiers="theme-root">
  <header class="validation__intro">
    <h1>Snippet: image</h1>
    <p>
      The <code>image</code> snippet renders a responsive <code>&lt;img&gt;</code> (or <code>&lt;picture&gt;</code> with
      mobile art direction). Sources are seeded store Files referenced via image_picker settings. Each case below tags
      its render with <code>data-case</code>.
    </p>
  </header>

  {% if desktop_image == blank %}
    <p class="validation__empty">
      No image seeded. Run <code>npm run seed:assets</code> and set the image_picker settings to
      <code>shopify://shop_images/landscape.png</code> / <code>portrait.png</code>.
    </p>
  {% else %}
    <div class="case" data-case="single">
      <span class="case__label">single — lazy / auto / full ladder</span>
      {% render 'image', image: desktop_image %}
    </div>

    <div class="case" data-case="art-direction">
      <span class="case__label">art-direction — &lt;picture&gt; + mobile &lt;source&gt;</span>
      {% render 'image', image: desktop_image, mobile_image: mobile_image %}
    </div>

    <div class="case" data-case="eager-high">
      <span class="case__label">eager + fetchpriority high</span>
      {% render 'image', image: desktop_image, loading: 'eager', fetchpriority: 'high' %}
    </div>

    <div class="case" data-case="low">
      <span class="case__label">fetchpriority low</span>
      {% render 'image', image: desktop_image, fetchpriority: 'low' %}
    </div>

    <div class="case" data-case="sizes-override">
      <span class="case__label">sizes_value override</span>
      {% render 'image', image: desktop_image, sizes_value: '(min-width: 48rem) 33vw, 100vw' %}
    </div>

    <div class="case" data-case="preload">
      <span class="case__label">preload — HTTP Link: rel=preload header</span>
      {% render 'image', image: desktop_image, preload: true %}
    </div>

    <div class="case" data-case="blank">
      <span class="case__label">blank image — snippet breaks, nothing renders</span>
      {% render 'image' %}
    </div>
  {% endif %}
</token-section>

{% schema %}
{
  "name": "Snippet: image",
  "tag": "section",
  "class": "shopify-section--validation--primitive--image",
  "settings": [
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image (art direction)" }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--primitive--image {
      token-section {
        max-inline-size: 80rem;
        margin-inline: auto;
        padding-block: 2rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .case {
        margin-block-start: 2.5rem;

        /* Fill the content track so the image renders at a representative width —
           with sizes="auto", candidate selection follows the rendered width, so a
           fixed cap here would shrink the image AND make sizes_value a visual no-op. */
        & picture {
          display: block;
        }

        & img {
          display: block;
          inline-size: 100%;
          block-size: auto;
        }
      }

      .case__label {
        display: block;
        margin-block-end: 0.5rem;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
        font-weight: 600;
        opacity: 0.7;
      }
    }
  }
{% endstylesheet %}
