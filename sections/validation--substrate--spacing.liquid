{% # Validation - Spacing v1.0.0 %}

{% comment %}
  Visual test page for the `spacing` metaobject. Iterates every entry
  and renders the real `spacer` snippet per entry with the entry's
  mobile/desktop values and a high-contrast accent background, so the
  resolved height is visible.

  Diagnostic intent:
  1. Each metaobject entry has `.mobile_value.value` and
     `.desktop_value.value` (px). The spacer snippet emits a
     breakpoint-driven CSS variable that resolves to one or the other
     based on viewport width.
  2. The metadata strip shows both values; the rendered spacer's height
     should match `mobile_value` below 640px and `desktop_value` at or
     above. Resize the viewport to validate the swap.
  3. Accent background paints the spacer's bounds clearly against the
     page.

  Reachable only at /?view=validation--substrate--spacing.
  See `.context/docs/validation.md` for the validation-suite convention.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
  assign accent_color = metaobjects.theme_color.accent
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Spacing</h1>
    <p>
      Source: <code>metaobjects.spacing.values</code>. Each entry holds
      a <code>mobile_value</code> and <code>desktop_value</code> pair
      (px). Emitted globally by <code>utility--css-variables</code> v1.13.0+
      as <code>--spacing-&lt;handle&gt;</code> (mobile in <code>:root</code>,
      desktop in nested <code>@media (width >= 48rem)</code>). Substrate-aligned
      handles (<code>xs</code>/<code>sm</code>/<code>md</code>/<code>lg</code>/<code>xl</code>)
      override the <code>layer-base.css</code> defaults via cascade position.
      Sections consume the namespace through <code>block_rhythm</code>, emitting
      <code>--block-rhythm: var(--spacing-&lt;handle&gt;)</code>. The validation
      here uses the <code>spacer</code> snippet at <code>breakpoint:40</code>
      (640px) to render each entry as a colored bar — height swaps from
      <code>mobile_value</code> to <code>desktop_value</code> when the
      viewport crosses 640px. Resize to validate.
    </p>
  </header>

  <ol class="spacing-suite">
    {% for spacing in metaobjects.spacing.values %}
      {% liquid
        assign handle = spacing.system.handle
        assign mobile = spacing.mobile_value.value | default: 0 | round
        assign desktop = spacing.desktop_value.value | default: 0 | round
      %}

      <li class="spacing-row">
        <header class="spacing-row__head">
          <code class="spacing-row__handle">{{ handle }}</code>
          <code class="spacing-row__metric">mobile:{{ mobile }}px</code>
          <code class="spacing-row__metric">desktop:{{ desktop }}px</code>
        </header>

        <div class="spacing-row__sample">
          {% render 'spacer',
            section: section,
            block_id: handle,
            breakpoint: '40',
            mobile_spacer_block_size: mobile,
            desktop_spacer_block_size: desktop,
            background_color: accent_color
          %}
        </div>
      </li>
    {% else %}
      <li class="spacing-suite__empty">
        No <code>spacing</code> metaobject entries defined.
      </li>
    {% endfor %}
  </ol>
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Spacing",
  "tag": "section",
  "class": "shopify-section--validation--substrate--spacing",
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--substrate--spacing {
      token-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .spacing-suite {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .spacing-suite__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      .spacing-row {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0.5rem;
      }

      .spacing-row__head {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.375rem 0.75rem;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
      }

      .spacing-row__handle {
        font-weight: 600;
      }

      .spacing-row__metric {
        opacity: 0.55;
      }

      .spacing-row__sample {
        max-inline-size: 32rem;

        & .shopify-block--spacer {
          border-radius: 0.25rem;
        }
      }
    }
  }
{% endstylesheet %}
