{% # Validation - Block - Media v1.0.0 %}

{% comment %}
  Block-validation harness for `media`. The JSON template at
  `templates/index.validation--primitive--media.json` bakes the test
  matrix; the section just renders them in a labelled list via
  `validation--block-labels`.

  Diagnostic intent:
  1. Each instance exercises a different combination of overlay,
     bleed, color-scheme, child-content, alignment, and spacing.
  2. Without an `image` or `video` asset (which can't live in JSON
     templates), the snippet's `placeholder_svg_tag` fallback fills
     each container so the wrapper rules (sizing, alignment, overlay)
     are observable.
  3. Child blocks nested inside a media instance render inside
     `<media-contents>` — the validation includes one entry with a
     title + button overlaid to exercise the contents pipeline.

  Variant sizing (`media_size`, `mobile_media_size`, `content_width`)
  is metaobject-typed and tested on the metaobject pages.

  Reachable only at /?view=validation--primitive--media.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<theme-section data-modifiers="theme-root,layout:column">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Block: media</h1>
    <p>
      Matrix in
      <code>templates/index.validation--primitive--media.json</code>. Each
      entry below exercises a different combination of overlay, bleed,
      color-scheme, child-content overlays, alignment, and spacing.
      Without an actual <code>image</code> or <code>video</code>
      asset (not expressible in JSON), the snippet's placeholder SVG
      stands in for the visual fill. Sizing variants
      (<code>media_size</code>, <code>content_width</code>) are tested
      on their metaobject pages.
    </p>
  </header>

  {% if section.blocks.size > 0 %}
    <div class="block-validation-suite">
      {% content_for 'blocks' %}
    </div>

    {% render 'validation--block-labels', section: section %}
  {% else %}
    <p class="block-validation-suite__empty">No blocks declared in the template.</p>
  {% endif %}
</theme-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Block: media",
  "tag": "section",
  "class": "shopify-section--validation--primitive--media",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--primitive--media {
      theme-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .block-validation-suite {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        padding-block-start: 1.5rem;
      }

      .block-validation-suite__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      .block-validation-suite > .shopify-block--media {
        position: relative;
        max-inline-size: 32rem;
        background-color: rgba(0, 0, 0, 0.04);
        outline: 1px dashed rgba(0, 0, 0, 0.18);
        outline-offset: -1px;
      }

      /* Bleed entries explicitly opt out of the cell's max-inline-size
         so the production rule's full-viewport behaviour is observable. */
      .block-validation-suite > .shopify-block--media[data-modifiers*='bleed'] {
        max-inline-size: none;
      }

      .block-validation-suite > .shopify-block--media::before {
        content: var(--block-label, '');
        position: absolute;
        inset-block-end: calc(100% + 0.375rem);
        inset-inline-start: 0;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
        font-weight: 600;
        opacity: 0.7;
        z-index: 1;
      }
    }
  }
{% endstylesheet %}
