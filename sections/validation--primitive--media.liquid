{% # Validation - Block - Media v1.1.0 %}

{% comment %}
  Changelog
  - v1.1.0 — token-section is now the real production theme-root grid (drop the `display: block` override + the `.block-validation-suite` flex wrapper, the `max-inline-size: 32rem` cell cap, and the dead `[data-modifiers*='bleed']` opt-out hack keyed off the removed bleed boolean), so blocks sit in the content track and bleed modifiers paint. Harness chrome + the layout-neutral outline/label indicator come from the shared `validation--harness-styles` snippet. Per `validation.md` § Harness layout.
  - v1.0.0 — initial

  Block-validation harness for `media`. The JSON template at
  `templates/index.validation--primitive--media.json` bakes the test
  matrix; the section just renders them in a labelled list via
  `validation--block-labels`.

  Diagnostic intent:
  1. Each instance exercises a different combination of overlay,
     bleed, color-scheme, child-content, alignment, and spacing.
  2. Without an `image` or `video` asset (which can't live in JSON
     templates), the snippet's `placeholder_svg_tag` fallback fills
     each container so the wrapper rules (sizing, alignment, overlay)
     are observable.
  3. Child blocks nested inside a media instance render inside
     `<media-contents>` — the validation includes one entry with a
     title + button overlaid to exercise the contents pipeline.

  Variant sizing (`media_size`, `mobile_media_size`, `content_width`)
  is metaobject-typed and tested on the metaobject pages.

  Reachable only at /?view=validation--primitive--media.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Block: media</h1>
    <p>
      Matrix in
      <code>templates/index.validation--primitive--media.json</code>. Each entry below exercises a different combination
      of overlay, bleed, color-scheme, child-content overlays, alignment, and spacing. Without an actual
      <code>image</code> or <code>video</code> asset (not expressible in JSON), the snippet's placeholder SVG stands in
      for the visual fill. Sizing variants (<code>media_size</code>, <code>content_width</code>) are tested on their
      metaobject pages.
    </p>
  </header>

  {% if section.blocks.size > 0 %}
    {% content_for 'blocks' %}

    {% render 'validation--block-labels', section: section %}
  {% else %}
    <p class="validation__empty">No blocks declared in the template.</p>
  {% endif %}
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}
{% render 'validation--harness-styles' %}

{% schema %}
{
  "name": "Block: media",
  "tag": "section",
  "class": "shopify-section--validation--primitive--media",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    /* Per-page exception: media is `overflow: hidden`, which clips the shared
       above-the-block use-case label. Place it inside the top-left corner
       instead (over the placeholder), above the overlay/contents stacking.
       The `[data-modifiers]` qualifier (always present on media) lifts this
       above the shared label rule's specificity so every inset wins — without
       it the two rules tie and the shared `inset-inline-start: 0` survives. */
    .shopify-section--validation--primitive--media token-section > .shopify-block--media[data-modifiers]::before {
      inset-block-start: 0.5rem;
      inset-block-end: auto;
      inset-inline-start: 0.5rem;
      z-index: 1;
    }
  }
{% endstylesheet %}
