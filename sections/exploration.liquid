{% # Exploration hub v1.0.0 %}

{% comment %}
  Hub for the bleed-API exploration scaffold. Lists every exploration section by variant.
  Reachable only at /?view=exploration — never linked from production templates.

  TEMPORARY SCAFFOLD. Delete this section + all `exploration-*` blocks + all
  `exploration--*` sections + their templates once shipped-block bleed API decisions land.
  See `BACKLOG.md` § Active exploration.
{% endcomment %}

<theme-section>
  <header class="exploration-hub__intro">
    <h1>Bleed exploration</h1>
    <p>
      Visual sandbox for the per-side / responsive bleed API hypothesis. Each page tests
      one composition. Reachable via querystring only; never linked from production.
    </p>
    <p class="exploration-hub__note">
      Tests run against <strong>experimental</strong> bleed blocks
      (<code>exploration-media</code>, <code>exploration-text</code>,
      <code>exploration-columns</code>) — shipped blocks are untouched. Scaffold deletes
      after API decisions land in production blocks.
    </p>
  </header>

  <section class="exploration-hub__group">
    <h2>Hero variants</h2>
    <ul>
      <li><a href="?view=exploration--bleed--hero-bleed-with-content">1. Bleed hero + content (in gutter)</a></li>
      <li><a href="?view=exploration--bleed--hero-nobleed-with-content">2. No-bleed hero + content (in gutter)</a></li>
      <li><a href="?view=exploration--bleed--double-hero-bleed-gap0">3. Double hero, full-bleed, gap = 0</a></li>
      <li><a href="?view=exploration--bleed--double-hero-nobleed-gap-gutter">4. Double hero, no bleed, gap = gutter width</a></li>
    </ul>
  </section>

  <section class="exploration-hub__group">
    <h2>Text + image responsive matrix</h2>
    <ul>
      <li><a href="?view=exploration--bleed--ti-l-bleed-both">5. Image left, mobile bleed + desktop bleed</a></li>
      <li><a href="?view=exploration--bleed--ti-r-bleed-desk">6. Image right, no mobile bleed, desktop bleed</a></li>
      <li><a href="?view=exploration--bleed--ti-l-bleed-mob">7. Image left, mobile bleed, no desktop bleed</a></li>
      <li><a href="?view=exploration--bleed--ti-r-bleed-none">8. Image right, no mobile bleed, no desktop bleed</a></li>
    </ul>
  </section>

  <section class="exploration-hub__group">
    <h2>Variations</h2>
    <ul>
      <li><a href="?view=exploration--bleed--gap-variations">9. Gap impact (0 / 16 / 48 / gutter-width)</a></li>
      <li><a href="?view=exploration--bleed--asymmetric">10. Asymmetric ⅔ + ⅓ with per-side bleed</a></li>
    </ul>
  </section>
</theme-section>

{% schema %}
{
  "name": "Exploration hub",
  "tag": "section",
  "class": "shopify-section--exploration",
  "settings": []
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--exploration {
      theme-section {
        display: block;
        padding-block: 2rem;
      }

      .exploration-hub__intro {
        max-inline-size: 80rem;
        margin-inline: auto;
        padding-inline: 1.5rem;
        margin-block-end: 2.5rem;

        h1 { margin-block-end: 0.5rem; }
        p {
          max-inline-size: 65ch;
          opacity: 0.75;
          margin-block: 0.5rem;
        }
        code {
          font-family: ui-monospace, monospace;
          font-size: 0.9em;
          background: rgba(0, 0, 0, 0.06);
          padding-inline: 0.25rem;
          border-radius: 0.25rem;
        }
      }

      .exploration-hub__note {
        font-size: 0.875rem;
        padding: 0.75rem 1rem;
        background: rgba(0, 0, 0, 0.04);
        border-inline-start: 3px solid currentColor;
        border-radius: 0.25rem;
      }

      .exploration-hub__group {
        max-inline-size: 80rem;
        margin-inline: auto;
        padding-inline: 1.5rem;
        margin-block-end: 2rem;

        h2 {
          margin-block-end: 0.5rem;
          padding-block-end: 0.5rem;
          border-block-end: 1px solid rgba(0, 0, 0, 0.12);
        }
        ul {
          list-style: none;
          padding: 0;
          margin: 0;
        }
        li {
          margin-block: 0.25rem;
        }
        a {
          display: inline-block;
          padding-block: 0.25rem;
          color: inherit;
          text-decoration: none;

          &:hover, &:focus-visible {
            text-decoration: underline;
            text-underline-offset: 0.2em;
          }
        }
      }
    }
  }
{% endstylesheet %}
