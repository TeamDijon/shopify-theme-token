{% # Exploration: T+I L mob+desk bleed v1.0.0 %}

{% capture contents %}{% content_for 'blocks' %}{% endcapture %}

{% render 'exploration--canvas', section: section, contents: contents %}

{% schema %}
{
  "name": "T+I L mob+desk bleed",
  "tag": "section",
  "class": "shopify-section--exploration",
  "blocks": [
    { "type": "exploration-media" },
    { "type": "exploration-text" },
    { "type": "exploration-columns" }
  ],
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Text + image (left), mobile bleed + desktop bleed" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Variant 5 — columns 2:1 (image wider, on left). Media bleeds inline-start on desktop (escapes left to viewport edge). On mobile (stacked), media bleeds both sides (full mobile bleed). Text stays in gutter on both viewports." }
  ]
}
{% endschema %}
