{% # Validation - Button style v1.0.0 %}

{% comment %}
  Visual test page for the `button_style` metaobject. Iterates every
  entry and renders four button-snippet invocations per entry — one for
  each branch of the button snippet — so the metaobject → snippet → CSS
  pipeline is exercised end-to-end.

  Diagnostic intent:
  1. The variant CSS rule at `[data-modifiers*='button-style:<handle>']`
     matches and applies the variant appearance (color, border, padding).
  2. Unrecognized handles fall through to the default solid-primary
     look. The strip flags this so a typo in the metaobject handle is
     visible without reading CSS.
  3. The four cells cover the snippet's conditional branches: plain
     link → `<a>`; no link → `<button type="button">`; with icon →
     leading SVG; new tab → target attrs + sr-only span.
  4. Hover and focus-visible states are validated by the developer
     interactively (no static rendering for those).

  Reachable only at /?view=validation--metaobject--button-style.
  See `.context/docs/validation.md` for the validation-suite convention.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
  assign known_handles = 'solid-primary,solid-secondary,outline,ghost,text-link' | split: ','
%}

<theme-section>
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Button style</h1>
    <p>
      Source: <code>metaobjects.button_style.values</code>. Consumed by
      the <code>button</code> snippet, which emits
      <code>data-modifiers="button-style:&lt;handle&gt;"</code> for the
      variant CSS to match. Each row exercises four snippet branches
      (plain link, with icon, no link, new-tab link). A handle outside the
      snippet's documented list is flagged — verify visually whether it
      picks up the intended variant or falls through to another rule via
      the snippet's substring selectors. Hover or tab into a button to
      validate states.
    </p>
  </header>

  <ol class="button-style-suite">
    {% for button_style in metaobjects.button_style.values %}
      {% liquid
        assign handle = button_style.system.handle
        assign is_known = false
        if known_handles contains handle
          assign is_known = true
        endif
      %}

      <li class="button-style-row">
        <header class="button-style-row__head">
          <code class="button-style-row__handle">{{ handle }}</code>
          <code class="button-style-row__modifier">data-modifiers="button-style:{{ handle }}"</code>
          {% if is_known %}
            <span class="button-style-row__flag" data-status="known">recognized</span>
          {% else %}
            <span class="button-style-row__flag" data-status="unknown">not in snippet's known list</span>
          {% endif %}
        </header>

        <div class="button-style-row__samples">
          <div class="button-style-cell">
            <div class="button-style-cell__sample">
              {% render 'button',
                section: section,
                block_id: handle | append: '-link',
                content: 'Sample button',
                link: '#',
                button_style: button_style
              %}
            </div>
            <span class="button-style-cell__label">link</span>
          </div>

          <div class="button-style-cell">
            <div class="button-style-cell__sample">
              {% render 'button',
                section: section,
                block_id: handle | append: '-icon',
                content: 'With icon',
                link: '#',
                button_style: button_style,
                icon: metaobjects.icon.arrow
              %}
            </div>
            <span class="button-style-cell__label">link + icon</span>
          </div>

          <div class="button-style-cell">
            <div class="button-style-cell__sample">
              {% render 'button',
                section: section,
                block_id: handle | append: '-button',
                content: 'No link',
                button_style: button_style
              %}
            </div>
            <span class="button-style-cell__label">&lt;button&gt;</span>
          </div>

          <div class="button-style-cell">
            <div class="button-style-cell__sample">
              {% render 'button',
                section: section,
                block_id: handle | append: '-newtab',
                content: 'External',
                link: 'https://example.com',
                open_in_new_tab: true,
                button_style: button_style
              %}
            </div>
            <span class="button-style-cell__label">link, new tab</span>
          </div>
        </div>
      </li>
    {% else %}
      <li class="button-style-suite__empty">
        No <code>button_style</code> metaobject entries defined.
      </li>
    {% endfor %}
  </ol>
</theme-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Validation - Button style",
  "tag": "section",
  "class": "shopify-section--validation--metaobject--button-style",
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--metaobject--button-style {
      theme-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .button-style-suite {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .button-style-suite__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      .button-style-row {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0.5rem;
      }

      .button-style-row__head {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.375rem 0.75rem;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
      }

      .button-style-row__handle {
        font-weight: 600;
      }

      .button-style-row__modifier {
        opacity: 0.55;
      }

      .button-style-row__flag {
        padding-block: 0.125rem;
        padding-inline: 0.375rem;
        border: 1px solid rgba(0, 0, 0, 0.18);
        border-radius: 0.25rem;
        font-size: 0.6875rem;

        &[data-status='unknown'] {
          color: #cc0033;
          border-color: rgba(204, 0, 51, 0.4);
        }
      }

      .button-style-row__samples {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;

        @media (width < 48rem) {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      .button-style-cell {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.625rem;
        padding: 1rem 0.75rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 0.375rem;
      }

      .button-style-cell__sample {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        min-block-size: 3.5rem;
      }

      .button-style-cell__label {
        font-family: ui-monospace, monospace;
        font-size: 0.75rem;
        opacity: 0.65;
      }
    }
  }
{% endstylesheet %}
