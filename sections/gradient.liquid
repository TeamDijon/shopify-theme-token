{% # Validation - Gradient v2.0.0 %}

{% comment %}
  Changelog
  - v2.0.0 — converted to the bare `gradient` page showcase (from the retired prefixed validation section) (`templates/page.gradient.json`, merchant-browsable Page template); class shortened to `shopify-section--gradient`

  Visual test page for the `gradient` metaobject. Iterates every entry and renders
  the emitted `--gradient-<handle>` as a large fill tile beside its metadata (angle +
  the two scheme-role endpoints) so the design-token pipeline can be eyeballed:

  - the tile proves `--gradient-<handle>` resolved (right angle, right role colors);
  - gradients are scheme-adaptive — their stops interpolate scheme *roles*
    (`background` / `foreground` / `primary`), so the same declaration re-resolves per
    color scheme. This page renders the default scheme; re-scope a subtree with a
    `color-scheme:<handle>` modifier to eyeball adaptivity.

  The reserved handle `background` is skipped — the color-scheme system owns
  `--gradient-background` (a separate per-scheme surface), not this metaobject.

  Merchant-browsable via the gradient page template (assign templates/page.gradient.json to a Page in admin).
  See `.context/docs/validation.md` for the validation-suite convention.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  <header class="validation__intro">
    <h1>Gradient</h1>
    <p>
      Source: <code>metaobjects.gradient.values</code>. Consumed via
      <code>background: var(--gradient-&lt;handle&gt;)</code>. Each tile renders one entry's emitted gradient; stops
      interpolate scheme <em>roles</em>, so the declaration re-resolves per color scheme. A failing entry is one whose
      tile is flat, wrongly angled, or renders a role that doesn't match its endpoints.
    </p>
  </header>

  <ol class="gradient-suite">
    {% for gradient in metaobjects.gradient.values %}
      {% liquid
        assign handle = gradient.system.handle
        if handle == 'background'
          continue
        endif
        assign angle = gradient.angle.value
        assign start_role = gradient.color_start.value
        assign end_role = gradient.color_end.value
      %}

      <li class="gradient" style="--fill: var(--gradient-{{ handle }});">
        <div class="gradient__tile" aria-hidden="true"></div>
        <header class="gradient__meta">
          <code class="gradient__handle">{{ handle }}</code>
          <dl class="gradient__fields">
            <div>
              <dt>angle</dt>
              <dd>{{ angle }}&deg;</dd>
            </div>
            <div>
              <dt>start</dt>
              <dd>
                <code>{{ start_role }}</code>
              </dd>
            </div>
            <div>
              <dt>end</dt>
              <dd>
                <code>{{ end_role }}</code>
              </dd>
            </div>
          </dl>
        </header>
      </li>
    {% else %}
      <li class="gradient-suite__empty">No <code>gradient</code> metaobject entries defined.</li>
    {% endfor %}
  </ol>
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Gradient",
  "tag": "section",
  "class": "shopify-section--gradient",
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--gradient {
      token-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .gradient-suite {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
        gap: 1.25rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .gradient-suite__empty {
        grid-column: 1 / -1;
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      .gradient {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 0.5rem;
      }

      .gradient__tile {
        aspect-ratio: 3 / 2;
        border-radius: 0.375rem;
        border: 1px solid rgba(0, 0, 0, 0.12);
        background: var(--fill);
      }

      .gradient__meta {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .gradient__handle {
        font-family: ui-monospace, monospace;
        font-weight: 600;
      }

      .gradient__fields {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 1rem;
        margin: 0;

        div {
          display: flex;
          align-items: baseline;
          gap: 0.35rem;
        }

        dt {
          font-size: 0.75rem;
          text-transform: uppercase;
          letter-spacing: 0.06em;
          opacity: 0.6;
        }

        dd {
          margin: 0;
          font-family: ui-monospace, monospace;
        }
      }
    }
  }
{% endstylesheet %}
