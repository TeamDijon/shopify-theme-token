{% # Validation - Block - Title v1.0.0 %}

{% comment %}
  Block-validation harness for `title`. The JSON template at
  `templates/index.validation--primitive--title.json` bakes the test
  matrix; the section just renders them in a labelled list via
  `validation--block-labels`.

  Diagnostic intent:
  1. Tag variants (h1..h6, p) emit the right HTML element and pick up
     the matching text_style auto-binding (the bare-tag binding emitted
     by `utility--css-variables`).
  2. Rich-text content (inline_richtext) renders nested inline elements
     (<em>, <strong>, <a>) cleanly.
  3. Top-spacing settings apply at the right breakpoint.

  Not covered by JSON (metaobject settings — store-specific GIDs):
  text_style override, icon, content_width, text_color. Verify those
  via the metaobject validation pages or interactively.

  Reachable only at /?view=validation--primitive--title.
  See `.context/docs/validation.md`.
{% endcomment %}

{% liquid
  assign max_inline_size = section.settings.max_inline_size
  assign base_selector = 'shopify-section-' | append: section.id
%}

<token-section data-modifiers="theme-root">
  {% render 'validation--breadcrumb' %}

  <header class="validation__intro">
    <h1>Block: title</h1>
    <p>
      Matrix in
      <code>templates/index.validation--primitive--title.json</code>. Each
      entry below is one block instance, labelled by its block id. Tag
      variants check the element emission and the bare-tag text-style
      auto-binding; the richtext entry checks inline rich-text rendering;
      the spacing entry checks top-margin application across breakpoints.
      Metaobject-typed settings (text_style, icon, content_width,
      text_color) are tested via their dedicated metaobject pages.
    </p>
  </header>

  {% if section.blocks.size > 0 %}
    <div class="block-validation-suite">
      {% content_for 'blocks' %}
    </div>

    {% render 'validation--block-labels', section: section %}
  {% else %}
    <p class="block-validation-suite__empty">No blocks declared in the template.</p>
  {% endif %}
</token-section>

{% capture dynamic_style %}
  {% if max_inline_size and max_inline_size != blank %}
    --max-inline-size: {{ max_inline_size }}px;
  {% endif %}
{% endcapture %}
{% render 'utility--dynamic-style', base_selector: base_selector, css_content: dynamic_style %}

{% schema %}
{
  "name": "Block: title",
  "tag": "section",
  "class": "shopify-section--validation--primitive--title",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "range",
      "id": "max_inline_size",
      "label": "Max width",
      "min": 800,
      "max": 1920,
      "step": 20,
      "unit": "px",
      "default": 1280
    }
  ]
}
{% endschema %}

{% stylesheet %}
  @layer components {
    .shopify-section--validation--primitive--title {
      token-section {
        display: block;
        max-inline-size: var(--max-inline-size, 80rem);
        margin-inline: auto;
        padding-block: 2rem;
        padding-inline: 1.5rem;
      }

      .validation__intro {
        margin-block-end: 2rem;

        h1 {
          margin-block-end: 0.5rem;
        }

        p {
          max-inline-size: 65ch;
          opacity: 0.75;
        }

        code {
          font-family: ui-monospace, monospace;
          font-size: 0.95em;
        }
      }

      .block-validation-suite {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        padding-block-start: 1.5rem;
      }

      .block-validation-suite__empty {
        padding: 1.5rem;
        border: 1px dashed currentColor;
        border-radius: 0.5rem;
        text-align: center;
        opacity: 0.7;
      }

      /* Float the DOM-id label above each title block. */
      .block-validation-suite > .shopify-block--title {
        position: relative;
      }

      .block-validation-suite > .shopify-block--title::before {
        content: var(--block-label, '');
        position: absolute;
        inset-block-end: calc(100% + 0.375rem);
        inset-inline-start: 0;
        font-family: ui-monospace, monospace;
        font-size: 0.8125rem;
        font-weight: 600;
        opacity: 0.7;
      }
    }
  }
{% endstylesheet %}
