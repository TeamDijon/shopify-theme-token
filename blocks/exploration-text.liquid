{% # Exploration Text block v1.0.0 %}

{% render 'exploration-text', section: section, block: block %}

{% schema %}
{
  "name": "Exploration: Text",
  "tag": null,
  "blocks": [],
  "settings": [
    {
      "type": "select",
      "id": "length",
      "label": "Length",
      "options": [
        { "value": "short", "label": "Short (1 sentence)" },
        { "value": "medium", "label": "Medium (2 sentences)" },
        { "value": "long", "label": "Long (full paragraph + extra)" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text alignment",
      "options": [
        { "value": "start", "label": "Start" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "End" }
      ],
      "default": "start"
    }
  ]
}
{% endschema %}
