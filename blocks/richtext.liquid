{% # Richtext block v1.3.0 %}

{% comment %}
  Changelog
  - v1.3.0 — top-margin override range changed to `-100…100` (was `0…200`): negative values pull a block tighter than the section rhythm; the 100–200 push range is dropped (use a `spacer` block for larger gaps). Step stays 2 — Shopify caps ranges at 101 steps. Pairs with `utility--block-layout-vars` v1.2.0 (emit on `!= 0`). See `.context/docs/schema-conventions.md` § Top-spacing pair.
  - v1.2.0 — drop `narrow` checkbox. Same concern (max-width cap) now expressed by the `content_width` metaobject alone — merchants seed a `text-narrow` entry (~65ch) and pick it on richtext blocks that should be narrow. Removes the overlapping `narrow` vs `content_width` editor surface.
  - v1.1.0 — add `text_align` setting (start/center/end)
  - v1.0.0 — initial
{% endcomment %}

{% render 'richtext', section: section, block: block %}

{% schema %}
{
  "name": "t:blocks.richtext.name",
  "tag": null,
  "blocks": [],
  "settings": [
    {
      "type": "header",
      "content": "t:blocks.richtext.settings.richtext.content"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:blocks.richtext.settings.content.label",
      "default": "t:blocks.richtext.settings.content.default"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "t:blocks.richtext.settings.text_align.label",
      "options": [
        { "value": "start", "label": "t:blocks.richtext.settings.text_align.options.start" },
        { "value": "center", "label": "t:blocks.richtext.settings.text_align.options.center" },
        { "value": "end", "label": "t:blocks.richtext.settings.text_align.options.end" }
      ],
      "default": "start"
    },
    {
      "type": "metaobject",
      "metaobject_type": "content_width",
      "id": "content_width",
      "label": "t:blocks.richtext.settings.content_width.label",
      "info": "t:blocks.richtext.settings.content_width.info"
    },
    {
      "type": "metaobject",
      "metaobject_type": "theme_color",
      "id": "text_color",
      "label": "t:blocks.richtext.settings.text_color.label",
      "info": "t:blocks.richtext.settings.text_color.info"
    },
    {
      "type": "header",
      "content": "t:blocks.richtext.settings.top_spacing.content"
    },
    {
      "type": "range",
      "id": "mobile_margin_block_start",
      "label": "t:blocks.richtext.settings.mobile_margin_block_start.label",
      "min": -100,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_margin_block_start",
      "label": "t:blocks.richtext.settings.desktop_margin_block_start.label",
      "min": -100,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:blocks.richtext.presets.richtext.name",
      "category": "t:blocks.richtext.presets.richtext.category"
    }
  ]
}
{% endschema %}
